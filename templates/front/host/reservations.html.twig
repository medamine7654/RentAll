{% extends 'front/base.html.twig' %}

{% block title %}Réservations - RentAll{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-8">
    <div class="container mx-auto px-4">
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-900 mb-2">Réservations de mes logements</h1>
            <p class="text-gray-600">Gérez les demandes et réservations pour vos annonces</p>
        </div>

        {# Section des demandes en attente #}
        {% if reservationsEnAttente|length > 0 %}
            <div class="mb-8">
                <div class="flex items-center mb-4">
                    <div class="bg-gradient-to-r from-orange-500 to-red-500 rounded-full p-2 mr-3">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-900">
                        Demandes en attente 
                        <span class="ml-2 px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-sm">{{ reservationsEnAttente|length }}</span>
                    </h2>
                </div>
                
                <div class="space-y-4">
                    {% for reservation in reservationsEnAttente %}
                        <div class="bg-white rounded-2xl shadow-lg p-6 border-2 border-orange-200 hover:border-orange-300 transition">
                            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                                {# Contenu principal - 9 colonnes #}
                                <div class="lg:col-span-9">
                                    <div class="flex items-start gap-4">
                                        <div class="bg-gradient-to-br from-orange-100 to-red-100 rounded-xl p-4 flex-shrink-0">
                                            <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                                            </svg>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <h3 class="text-xl font-bold text-gray-900 mb-3">{{ reservation.logement.titre }}</h3>
                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
                                                <div class="flex items-center text-gray-600">
                                                    <svg class="w-5 h-5 mr-2 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                                    </svg>
                                                    <span class="font-medium truncate">
                                                        {% if reservation.locataire.prenom and reservation.locataire.nom %}
                                                            {{ reservation.locataire.prenom }} {{ reservation.locataire.nom }}
                                                        {% else %}
                                                            {{ reservation.locataire.email }}
                                                        {% endif %}
                                                    </span>
                                                </div>
                                                <div class="flex items-center text-gray-600">
                                                    <svg class="w-5 h-5 mr-2 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                                    </svg>
                                                    <span class="font-medium">{{ reservation.nombrePersonnes }} personne(s)</span>
                                                </div>
                                                <div class="flex items-center text-gray-600">
                                                    <svg class="w-5 h-5 mr-2 text-purple-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                                    </svg>
                                                    <span class="font-medium">{{ reservation.dateDebut|date('d/m/Y') }} → {{ reservation.dateFin|date('d/m/Y') }}</span>
                                                </div>
                                                <div class="flex items-center text-gray-600">
                                                    <svg class="w-5 h-5 mr-2 text-yellow-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                    </svg>
                                                    <span class="font-medium">{{ reservation.nombreNuits }} nuit(s)</span>
                                                </div>
                                            </div>
                                            <div class="mt-3 flex items-center">
                                                <span class="text-2xl font-bold text-gray-900">{{ reservation.montantTotal }}€</span>
                                                <span class="ml-2 text-sm text-gray-500">montant total</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                {# Boutons d'action - 3 colonnes #}
                                <div class="lg:col-span-3">
                                    <div class="flex flex-col gap-3 h-full justify-center">
                                        <form method="post" action="{{ path('host_reservation_accept', {id: reservation.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ reservation.id) }}">
                                            <button type="submit" class="w-full bg-gradient-to-r from-green-600 to-emerald-600 text-white px-6 py-3 rounded-xl hover:from-green-700 hover:to-emerald-700 transition-all duration-200 font-bold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                                                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                </svg>
                                                Accepter
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('host_reservation_reject', {id: reservation.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ reservation.id) }}">
                                            <button type="submit" class="w-full bg-gradient-to-r from-red-600 to-pink-600 text-white px-6 py-3 rounded-xl hover:from-red-700 hover:to-pink-700 transition-all duration-200 font-bold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                                                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                                </svg>
                                                Refuser
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# Section des autres réservations #}
        <div class="mb-4">
            <h2 class="text-2xl font-bold text-gray-900">Historique des réservations</h2>
        </div>

        {% if autresReservations|length > 0 %}
            <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Logement</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Client</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Dates</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Personnes</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Montant</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            {% for reservation in autresReservations %}
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="px-4 py-3">
                                        <p class="font-medium text-gray-900">{{ reservation.logement.titre }}</p>
                                    </td>
                                    <td class="px-4 py-3">
                                        {% if reservation.locataire.prenom and reservation.locataire.nom %}
                                            {{ reservation.locataire.prenom }} {{ reservation.locataire.nom }}
                                        {% else %}
                                            {{ reservation.locataire.email }}
                                        {% endif %}
                                    </td>
                                    <td class="px-4 py-3 text-sm">
                                        <p>{{ reservation.dateDebut|date('d/m/Y') }}</p>
                                        <p class="text-gray-500">au {{ reservation.dateFin|date('d/m/Y') }}</p>
                                        <p class="text-xs text-gray-400">{{ reservation.nombreNuits }} nuit(s)</p>
                                    </td>
                                    <td class="px-4 py-3">
                                        {{ reservation.nombrePersonnes }} pers.
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="font-semibold text-gray-900">{{ reservation.montantTotal }}€</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        {% if reservation.statut == 'confirmee' %}
                                            <span class="px-3 py-1.5 bg-gradient-to-r from-green-100 to-emerald-100 text-green-700 rounded-full text-xs font-bold border border-green-200">✓ Confirmée</span>
                                        {% elseif reservation.statut == 'annulee' %}
                                            <span class="px-3 py-1.5 bg-gradient-to-r from-gray-100 to-gray-200 text-gray-700 rounded-full text-xs font-bold border border-gray-300">✕ Annulée</span>
                                        {% elseif reservation.statut == 'refusee' %}
                                            <span class="px-3 py-1.5 bg-gradient-to-r from-red-100 to-pink-100 text-red-700 rounded-full text-xs font-bold border border-red-200">✕ Refusée</span>
                                        {% else %}
                                            <span class="px-3 py-1.5 bg-gradient-to-r from-yellow-100 to-orange-100 text-yellow-700 rounded-full text-xs font-bold border border-yellow-200">⏳ {{ reservation.statut }}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% elseif reservationsEnAttente|length == 0 %}
            <div class="bg-white rounded-xl shadow-lg p-12">
                <div class="flex flex-col items-center justify-center text-center">
                    <div class="rounded-full bg-gradient-to-br from-gray-100 to-gray-200 p-8 mb-6">
                        <svg class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-2">Aucune réservation</h3>
                    <p class="text-gray-600 mb-6">
                        Vous n'avez pas encore de réservations pour vos logements
                    </p>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}