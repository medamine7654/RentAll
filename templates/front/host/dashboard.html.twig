{% extends 'front/base.html.twig' %}

{% block title %}Dashboard Hôte - RentAll{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-8">
    <div class="container mx-auto px-4">
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-900 mb-2">Dashboard Hôte</h1>
            <p class="text-gray-600">Gérez vos logements et réservations</p>
        </div>

        {# Statistiques #}
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-xl shadow-lg p-6">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-gray-600 text-sm font-medium">Logements</h3>
                    <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                </div>
                <p class="text-3xl font-bold text-gray-900">{{ stats.totalLogements }}</p>
            </div>

            <div class="bg-white rounded-xl shadow-lg p-6">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-gray-600 text-sm font-medium">Réservations</h3>
                    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <p class="text-3xl font-bold text-gray-900">{{ stats.totalReservations }}</p>
            </div>

            <div class="bg-white rounded-xl shadow-lg p-6">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-gray-600 text-sm font-medium">Confirmées</h3>
                    <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <p class="text-3xl font-bold text-gray-900">{{ stats.reservationsConfirmees }}</p>
            </div>

            <div class="bg-white rounded-xl shadow-lg p-6">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-gray-600 text-sm font-medium">Revenu Total</h3>
                    <svg class="w-8 h-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <p class="text-3xl font-bold text-gray-900">{{ stats.revenuTotal|number_format(2) }}€</p>
            </div>
        </div>

        {# Actions rapides #}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <a href="{{ path('host_logement_new') }}" class="bg-blue-600 text-white rounded-xl shadow-lg p-6 hover:bg-blue-700 transition flex items-center justify-between">
                <div>
                    <h3 class="text-xl font-bold mb-1">Ajouter un logement</h3>
                    <p class="text-blue-100 text-sm">Créer une nouvelle annonce</p>
                </div>
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
            </a>

            <a href="{{ path('host_logements') }}" class="bg-green-600 text-white rounded-xl shadow-lg p-6 hover:bg-green-700 transition flex items-center justify-between">
                <div>
                    <h3 class="text-xl font-bold mb-1">Mes logements</h3>
                    <p class="text-green-100 text-sm">Gérer mes annonces</p>
                </div>
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
            </a>

            <a href="{{ path('host_reservations') }}" class="bg-purple-600 text-white rounded-xl shadow-lg p-6 hover:bg-purple-700 transition flex items-center justify-between">
                <div>
                    <h3 class="text-xl font-bold mb-1">Réservations</h3>
                    <p class="text-purple-100 text-sm">Voir toutes les réservations</p>
                </div>
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
            </a>
        </div>

        {# Dernières réservations #}
        <div class="bg-white rounded-xl shadow-lg p-6">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Dernières réservations</h2>
            
            {% if reservations|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Logement</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Client</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Dates</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Montant</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            {% for reservation in reservations|slice(0, 10) %}
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-3">{{ reservation.logement.titre }}</td>
                                    <td class="px-4 py-3">
                                        {% if reservation.locataire.prenom and reservation.locataire.nom %}
                                            {{ reservation.locataire.prenom }} {{ reservation.locataire.nom }}
                                        {% else %}
                                            {{ reservation.locataire.email }}
                                        {% endif %}
                                    </td>
                                    <td class="px-4 py-3 text-sm">
                                        {{ reservation.dateDebut|date('d/m/Y') }} - {{ reservation.dateFin|date('d/m/Y') }}
                                    </td>
                                    <td class="px-4 py-3 font-semibold">{{ reservation.montantTotal }}€</td>
                                    <td class="px-4 py-3">
                                        {% if reservation.statut == 'confirmee' %}
                                            <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Confirmée</span>
                                        {% elseif reservation.statut == 'annulee' %}
                                            <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs font-medium">Annulée</span>
                                        {% else %}
                                            <span class="px-2 py-1 bg-yellow-100 text-yellow-700 rounded-full text-xs font-medium">{{ reservation.statut }}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-gray-500 text-center py-8">Aucune réservation pour le moment</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
