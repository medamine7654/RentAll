{% extends 'front/base.html.twig' %}

{% block title %}Book Professional Services - RentAll{% endblock %}

{% block body %}
{# Hero Section #}
<div class="bg-gradient-to-r from-green-600 to-teal-600 py-16 mb-8">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold text-white mb-4 animate-fade-in">
            Book Professional Services
        </h1>
        <p class="text-xl text-white/90 mb-8">
            Connect with skilled professionals for all your needs
        </p>
        {% if is_granted('ROLE_HOST') %}
            <a href="{{ path('host_service_new') }}" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-green-600 rounded-xl font-semibold hover:bg-green-50 transition-all shadow-lg">
                <i class="fas fa-plus-circle"></i>
                Proposer un service
            </a>
        {% endif %}
    </div>
</div>

<div class="container mx-auto px-4 pb-20">
    {# Smart Search Bar #}
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-4 mb-8 -mt-12 relative z-10">
        {{ form_start(searchForm, {'attr': {'class': 'space-y-4', 'id': 'search-form'}}) }}
            {# Quick Search Bar #}
            <div class="flex flex-col md:flex-row gap-3">
                <div class="flex-1">
                    <div class="relative">
                        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        {{ form_widget(searchForm.query, {'attr': {'class': 'w-full pl-12 pr-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all text-lg', 'placeholder': 'Search services...'}}) }}
                    </div>
                </div>
                <button type="button" id="filter-toggle" class="md:w-auto px-6 py-4 bg-gradient-to-r from-green-600 to-teal-600 text-white rounded-xl font-semibold hover:shadow-lg transition-all flex items-center justify-center gap-2 cursor-pointer">
                    <i class="fas fa-sliders-h" id="filter-icon"></i>
                    <span>Filters</span>
                    <span id="active-filters-count" class="hidden bg-white text-green-600 rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold">0</span>
                </button>
                <button type="submit" class="md:w-auto px-8 py-4 bg-green-600 text-white rounded-xl font-semibold hover:bg-green-700 transition-all flex items-center justify-center gap-2">
                    <i class="fas fa-search"></i>
                    <span>Search</span>
                </button>
            </div>

            {# Active Filters Chips #}
            <div id="active-filters-chips" class="hidden flex-wrap gap-2"></div>

            {# Quick Clear All Button #}
            <div id="quick-clear-container" class="hidden">
                <a href="{{ path('app_services') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition-all text-sm font-medium">
                    <i class="fas fa-times-circle"></i>
                    <span>Clear All Filters</span>
                </a>
            </div>

            {# Collapsible Advanced Filters #}
            <div id="advanced-filters" class="hidden space-y-6 pt-4 border-t border-gray-200">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div class="space-y-3">
                        <label class="flex items-center gap-2 text-sm font-bold text-gray-700 uppercase tracking-wide">
                            <div class="w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center">
                                <i class="fas fa-tag text-green-600"></i>
                            </div>
                            <span>Category</span>
                        </label>
                        {{ form_widget(searchForm.category, {'attr': {'class': 'w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all bg-gray-50 hover:bg-white'}}) }}
                    </div>

                    <div class="space-y-3">
                        <label class="flex items-center gap-2 text-sm font-bold text-gray-700 uppercase tracking-wide">
                            <div class="w-8 h-8 rounded-lg bg-teal-100 flex items-center justify-center">
                                <i class="fas fa-map-marker-alt text-teal-600"></i>
                            </div>
                            <span>Location</span>
                        </label>
                        {{ form_widget(searchForm.location, {'attr': {'class': 'w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-teal-500 focus:border-teal-500 transition-all bg-gray-50 hover:bg-white', 'placeholder': 'Enter city or area...'}}) }}
                    </div>

                    <div class="space-y-3">
                        <label class="flex items-center gap-2 text-sm font-bold text-gray-700 uppercase tracking-wide">
                            <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center">
                                <i class="fas fa-sort text-blue-600"></i>
                            </div>
                            <span>Sort By</span>
                        </label>
                        {{ form_widget(searchForm.sortBy, {'attr': {'class': 'w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-gray-50 hover:bg-white'}}) }}
                    </div>
                </div>

                <div class="space-y-4">
                    <label class="flex items-center gap-2 text-sm font-bold text-gray-700 uppercase tracking-wide">
                        <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center">
                            <i class="fas fa-euro-sign text-emerald-600"></i>
                        </div>
                        <span>Price Range</span>
                    </label>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-gray-600 mb-2">Minimum</label>
                            {{ form_widget(searchForm.minPrice, {'attr': {'class': 'w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all bg-gray-50 hover:bg-white', 'placeholder': '€0', 'type': 'number', 'min': '0'}}) }}
                        </div>
                        <div>
                            <label class="block text-xs text-gray-600 mb-2">Maximum</label>
                            {{ form_widget(searchForm.maxPrice, {'attr': {'class': 'w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all bg-gray-50 hover:bg-white', 'placeholder': '€500', 'type': 'number', 'min': '0'}}) }}
                        </div>
                    </div>
                    <div id="price-range-display" class="text-center text-sm text-gray-600 font-medium"></div>
                </div>

                <div class="flex gap-3 pt-4 border-t border-gray-200">
                    <button type="submit" class="flex-1 px-6 py-3 bg-gradient-to-r from-green-600 to-teal-600 text-white rounded-xl font-semibold hover:shadow-lg transition-all flex items-center justify-center gap-2">
                        <i class="fas fa-search"></i>
                        <span>Apply Filters</span>
                    </button>
                    <button type="button" id="clear-filters" class="px-6 py-3 bg-gray-100 text-gray-700 rounded-xl font-semibold hover:bg-gray-200 transition-all flex items-center justify-center gap-2">
                        <i class="fas fa-times"></i>
                        <span>Clear All</span>
                    </button>
                </div>
            </div>
        {{ form_end(searchForm) }}
    </div>

    {# Results Header #}
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <div class="text-lg font-semibold text-gray-900">
                <i class="fas fa-briefcase text-green-600 mr-2"></i>
                {{ pagination.getTotalItemCount }} {{ pagination.getTotalItemCount == 1 ? 'Service' : 'Services' }}
            </div>
            {% if pagination.getTotalItemCount > 0 %}
                <span class="text-sm text-gray-500">
                    Page {{ pagination.currentPageNumber }} of {{ pagination.pageCount }}
                </span>
            {% endif %}
        </div>
    </div>

    {# Services Grid #}
    <section>
        {% if servicesWithScores|length > 0 %}
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                {% for item in servicesWithScores %}
                    {% set service = item.service %}
                    {% set qualityScore = item.qualityScore %}
                    <div class="group rounded-2xl border border-gray-200 bg-white shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden hover-lift">
                        <div class="relative overflow-hidden">
                            {% if service.imageName %}
                                <img src="{{ asset('uploads/services/' ~ service.imageName) }}"
                                     alt="{{ service.name }}"
                                     class="w-full h-56 object-cover group-hover:scale-110 transition-transform duration-300"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                                <div class="w-full h-56 bg-gradient-to-br from-green-100 to-teal-200 items-center justify-center hidden">
                                    <i class="fas fa-briefcase text-green-400 text-6xl"></i>
                                </div>
                            {% else %}
                                <div class="w-full h-56 bg-gradient-to-br from-green-100 to-teal-200 flex items-center justify-center group-hover:from-green-200 group-hover:to-teal-300 transition-all">
                                    <i class="fas fa-briefcase text-green-400 text-6xl"></i>
                                </div>
                            {% endif %}
                            
                            <div class="absolute top-3 left-3 right-3 flex items-start justify-between">
                                {% if service.category %}
                                    <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold bg-white/90 backdrop-blur-sm text-gray-900 shadow-lg">
                                        <i class="{{ service.category.icon }} mr-1.5"></i>
                                        {{ service.category.name }}
                                    </span>
                                {% endif %}
                                <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold {{ qualityScore.rating.bgClass }} {{ qualityScore.rating.textClass }} shadow-lg">
                                    <i class="fas {{ qualityScore.rating.icon }} mr-1.5"></i>
                                    {{ qualityScore.percentage }}%
                                </span>
                            </div>

                            {% if app.user %}
                                <form method="post" action="{{ path('app_favorites_toggle', {type: 'service', id: service.id}) }}" class="absolute top-3 right-3">
                                    <button type="submit" class="w-10 h-10 rounded-full {{ item.isFavorite ? 'bg-red-500 text-white' : 'bg-white/90 backdrop-blur-sm text-gray-700' }} shadow-lg hover:scale-110 transition-all flex items-center justify-center">
                                        <i class="fas fa-heart"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                        
                        <div class="p-5 space-y-3">
                            <div>
                                <h3 class="font-bold text-lg text-gray-900 mb-1 line-clamp-1 group-hover:text-green-600 transition-colors">
                                    {{ service.name }}
                                </h3>
                                {% if service.location %}
                                    <p class="text-sm text-gray-500 flex items-center gap-1">
                                        <i class="fas fa-map-marker-alt text-teal-500"></i>
                                        {{ service.location }}
                                    </p>
                                {% endif %}
                            </div>

                            {% if service.description %}
                                <p class="text-sm text-gray-600 line-clamp-2">
                                    {{ service.description }}
                                </p>
                            {% endif %}

                            {% if service.durationMinutes %}
                                <div class="flex items-center gap-2 text-sm text-gray-600">
                                    <i class="fas fa-clock text-blue-500"></i>
                                    <span>{{ (service.durationMinutes / 60)|round(1) }} hours</span>
                                </div>
                            {% endif %}

                            <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                                <div>
                                    <span class="text-2xl font-bold text-gray-900">€{{ service.basePrice }}</span>
                                </div>
                                <a href="{{ path('app_service_show', {id: service.id}) }}" 
                                   class="px-4 py-2 bg-gradient-to-r from-green-600 to-teal-600 text-white rounded-lg font-semibold hover:shadow-lg transition-all text-sm">
                                    View
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {% if pagination.getTotalItemCount > 12 %}
                <div class="mt-12 flex justify-center">
                    <nav class="inline-flex rounded-xl shadow-lg overflow-hidden border border-gray-200">
                        {% if pagination.currentPageNumber > 1 %}
                            <a href="{{ path('app_services', app.request.query.all|merge({'page': pagination.currentPageNumber - 1})) }}" 
                               class="px-4 py-3 bg-white text-gray-700 hover:bg-gray-50 font-medium transition-colors flex items-center gap-2">
                                <i class="fas fa-chevron-left"></i>
                                <span class="hidden sm:inline">Previous</span>
                            </a>
                        {% endif %}

                        {% set startPage = max(1, pagination.currentPageNumber - 2) %}
                        {% set endPage = min(pagination.pageCount, pagination.currentPageNumber + 2) %}
                        
                        {% for page in startPage..endPage %}
                            {% if page == pagination.currentPageNumber %}
                                <span class="px-5 py-3 bg-gradient-to-r from-green-600 to-teal-600 text-white font-bold">
                                    {{ page }}
                                </span>
                            {% else %}
                                <a href="{{ path('app_services', app.request.query.all|merge({'page': page})) }}" 
                                   class="px-5 py-3 bg-white text-gray-700 hover:bg-gray-50 font-medium transition-colors">
                                    {{ page }}
                                </a>
                            {% endif %}
                        {% endfor %}

                        {% if pagination.currentPageNumber < pagination.pageCount %}
                            <a href="{{ path('app_services', app.request.query.all|merge({'page': pagination.currentPageNumber + 1})) }}" 
                               class="px-4 py-3 bg-white text-gray-700 hover:bg-gray-50 font-medium transition-colors flex items-center gap-2">
                                <span class="hidden sm:inline">Next</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        {% endif %}
                    </nav>
                </div>
            {% endif %}
        {% else %}
            <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="w-24 h-24 rounded-full bg-gradient-to-br from-green-100 to-teal-100 flex items-center justify-center mb-6">
                    <i class="fas fa-search text-4xl text-green-400"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">No Services Found</h3>
                <p class="text-gray-600 mb-6 max-w-md">
                    We couldn't find any services matching your criteria. Try adjusting your filters or search terms.
                </p>
                <button type="button" id="clear-filters-empty" class="px-6 py-3 bg-gradient-to-r from-green-600 to-teal-600 text-white rounded-xl font-semibold hover:shadow-lg transition-all">
                    Clear All Filters
                </button>
            </div>
        {% endif %}
    </section>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const filterToggle = document.getElementById('filter-toggle');
    const advancedFilters = document.getElementById('advanced-filters');
    const clearFiltersBtn = document.getElementById('clear-filters');
    const clearFiltersEmptyBtn = document.getElementById('clear-filters-empty');
    const activeFiltersCount = document.getElementById('active-filters-count');
    const activeFiltersChips = document.getElementById('active-filters-chips');
    const quickClearContainer = document.getElementById('quick-clear-container');
    const form = document.getElementById('search-form');
    
    if (filterToggle && advancedFilters) {
        filterToggle.onclick = function(e) {
            e.preventDefault();
            e.stopPropagation();
            const isHidden = advancedFilters.classList.contains('hidden');
            if (isHidden) {
                advancedFilters.classList.remove('hidden');
            } else {
                advancedFilters.classList.add('hidden');
            }
            const icon = document.getElementById('filter-icon');
            if (icon) {
                if (isHidden) {
                    icon.classList.remove('fa-sliders-h');
                    icon.classList.add('fa-times');
                } else {
                    icon.classList.remove('fa-times');
                    icon.classList.add('fa-sliders-h');
                }
            }
            return false;
        };
    }
    
    function updateActiveFilters() {
        if (!form) return;
        const formData = new FormData(form);
        let count = 0;
        const chips = [];
        
        const query = formData.get('search_filter[query]');
        const category = formData.get('search_filter[category]');
        const location = formData.get('search_filter[location]');
        const minPrice = formData.get('search_filter[minPrice]');
        const maxPrice = formData.get('search_filter[maxPrice]');
        
        if (query && query.trim() !== '') {
            count++;
            chips.push({label: `"${query}"`, field: 'query'});
        }
        if (category && category !== '') {
            count++;
            const categorySelect = form.querySelector('[name="search_filter[category]"]');
            if (categorySelect && categorySelect.selectedIndex > 0) {
                const categoryText = categorySelect.options[categorySelect.selectedIndex].text;
                chips.push({label: categoryText, field: 'category'});
            }
        }
        if (location && location.trim() !== '') {
            count++;
            chips.push({label: `📍 ${location}`, field: 'location'});
        }
        if (minPrice && minPrice !== '') {
            count++;
            chips.push({label: `Min: €${minPrice}`, field: 'minPrice'});
        }
        if (maxPrice && maxPrice !== '') {
            count++;
            chips.push({label: `Max: €${maxPrice}`, field: 'maxPrice'});
        }
        
        if (activeFiltersCount) {
            if (count > 0) {
                activeFiltersCount.textContent = count;
                activeFiltersCount.classList.remove('hidden');
                activeFiltersCount.classList.add('flex');
            } else {
                activeFiltersCount.classList.add('hidden');
                activeFiltersCount.classList.remove('flex');
            }
        }
        
        if (activeFiltersChips) {
            if (chips.length > 0) {
                activeFiltersChips.classList.remove('hidden');
                activeFiltersChips.classList.add('flex');
                activeFiltersChips.innerHTML = chips.map(chip => `
                    <span class="inline-flex items-center gap-2 px-3 py-2 bg-green-100 text-green-800 rounded-full text-sm font-semibold shadow-sm">
                        <span>${chip.label}</span>
                        <button type="button" class="hover:text-green-900 hover:bg-green-200 rounded-full w-5 h-5 flex items-center justify-center transition-all" onclick="removeFilter('${chip.field}')">
                            <i class="fas fa-times text-xs"></i>
                        </button>
                    </span>
                `).join('');
            } else {
                activeFiltersChips.classList.add('hidden');
                activeFiltersChips.classList.remove('flex');
            }
        }
        
        if (quickClearContainer) {
            if (count > 0) {
                quickClearContainer.classList.remove('hidden');
            } else {
                quickClearContainer.classList.add('hidden');
            }
        }
    }
    
    window.removeFilter = function(field) {
        const currentUrl = new URL(window.location.href);
        const params = new URLSearchParams(currentUrl.search);
        
        if (field === 'query') {
            params.delete('search_filter[query]');
        } else if (field === 'category') {
            params.delete('search_filter[category]');
        } else if (field === 'location') {
            params.delete('search_filter[location]');
        } else if (field === 'minPrice') {
            params.delete('search_filter[minPrice]');
        } else if (field === 'maxPrice') {
            params.delete('search_filter[maxPrice]');
        }
        
        const newUrl = currentUrl.pathname + (params.toString() ? '?' + params.toString() : '');
        window.location.href = newUrl;
    };
    
    function clearAllFilters(e) {
        if (e) e.preventDefault();
        window.location.href = '{{ path('app_services') }}';
    }
    
    if (clearFiltersBtn) {
        clearFiltersBtn.onclick = clearAllFilters;
    }
    if (clearFiltersEmptyBtn) {
        clearFiltersEmptyBtn.onclick = clearAllFilters;
    }
    
    const minPriceInput = form ? form.querySelector('[name="search_filter[minPrice]"]') : null;
    const maxPriceInput = form ? form.querySelector('[name="search_filter[maxPrice]"]') : null;
    const priceRangeDisplay = document.getElementById('price-range-display');
    
    function updatePriceDisplay() {
        if (!minPriceInput || !maxPriceInput || !priceRangeDisplay) return;
        const min = minPriceInput.value || '0';
        const max = maxPriceInput.value || '∞';
        priceRangeDisplay.textContent = `€${min} - €${max}`;
    }
    
    if (minPriceInput && maxPriceInput) {
        minPriceInput.addEventListener('input', updatePriceDisplay);
        maxPriceInput.addEventListener('input', updatePriceDisplay);
        updatePriceDisplay();
    }
    
    updateActiveFilters();
    
    if (form) {
        form.addEventListener('change', updateActiveFilters);
    }
});
</script>
{% endblock %}

