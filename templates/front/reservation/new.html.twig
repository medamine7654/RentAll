{% extends 'front/base.html.twig' %}

{% block title %}Réserver {{ logement.titre }} - RentAll{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-8">
    <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
            {# Messages flash #}
            {% for message in app.flashes('success') %}
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('info') %}
                <div class="bg-blue-100 border border-blue-400 text-blue-700 px-4 py-3 rounded mb-4">
                    {{ message }}
                </div>
            {% endfor %}

            <div class="mb-8">
                <h1 class="text-4xl font-bold text-gray-900 mb-2">Réserver ce logement</h1>
                <p class="text-gray-600 text-lg">Complétez les informations de votre séjour</p>
            </div>

            <div class="grid lg:grid-cols-3 gap-8">
                {# Formulaire de réservation #}
                <div class="lg:col-span-2">
                    <div class="bg-white p-8 rounded-xl shadow-lg">
                        <h2 class="text-2xl font-bold text-gray-900 mb-6">Informations de réservation</h2>
                        
                        {{ form_start(form, {'attr': {'id': 'reservationForm', 'data-turbo': 'false'}}) }}
                            {# Afficher toutes les erreurs du formulaire #}
                            {{ form_errors(form) }}
                            
                            <div class="space-y-6">
                                <div class="grid md:grid-cols-2 gap-6">
                                    <div>
                                        {{ form_label(form.dateDebut, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                                        {{ form_widget(form.dateDebut) }}
                                        {{ form_errors(form.dateDebut) }}
                                    </div>

                                    <div>
                                        {{ form_label(form.dateFin, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                                        {{ form_widget(form.dateFin) }}
                                        {{ form_errors(form.dateFin) }}
                                    </div>
                                </div>

                                <div>
                                    {{ form_label(form.nombrePersonnes, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                                    {{ form_widget(form.nombrePersonnes) }}
                                    {{ form_errors(form.nombrePersonnes) }}
                                    <p class="text-sm text-gray-500 mt-1">Capacité maximale : {{ logement.capacite }} personne(s)</p>
                                </div>

                                {# Calcul du prix en temps réel #}
                                <div id="prixCalcule" class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-gray-700">Prix par nuit</span>
                                        <span class="font-semibold">{{ logement.prixParNuit }}€</span>
                                    </div>
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-gray-700">Nombre de nuits</span>
                                        <span class="font-semibold" id="nombreNuits">-</span>
                                    </div>
                                    <div class="border-t border-blue-300 pt-2 flex justify-between items-center">
                                        <span class="text-lg font-bold text-gray-900">Total</span>
                                        <span class="text-2xl font-bold text-blue-600" id="montantTotal">-</span>
                                    </div>
                                </div>

                                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                                    <p class="text-sm text-yellow-800">
                                        <strong>Politique d'annulation :</strong> Annulation gratuite jusqu'à 3 jours avant l'arrivée.
                                    </p>
                                </div>

                                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                                    <div class="flex items-start">
                                        <svg class="w-5 h-5 text-green-600 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                        </svg>
                                        <div>
                                            <p class="text-sm font-semibold text-green-900">Vérification automatique de disponibilité</p>
                                            <p class="text-sm text-green-800">Le système vérifie qu'aucune autre réservation n'existe pour ces dates.</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="flex gap-4">
                                    <button type="submit" class="flex-1 bg-blue-600 text-white py-4 rounded-lg hover:bg-blue-700 font-bold text-lg shadow-lg transition">
                                        Confirmer la réservation
                                    </button>
                                    <a href="{{ path('app_home') }}" 
                                       class="flex-1 bg-gray-200 text-gray-800 py-4 rounded-lg hover:bg-gray-300 font-semibold text-center flex items-center justify-center transition">
                                        Annuler
                                    </a>
                                </div>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>

                {# Résumé du logement #}
                <div class="lg:col-span-1">
                    <div class="bg-white p-6 rounded-xl shadow-lg sticky top-24">
                        {% if logement.image %}
                            <img src="{{ logement.image }}" class="w-full h-48 object-cover rounded-lg mb-4" alt="{{ logement.titre }}">
                        {% else %}
                            <div class="w-full h-48 bg-gradient-to-br from-blue-400 to-blue-600 rounded-lg mb-4 flex items-center justify-center">
                                <svg class="w-16 h-16 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                                </svg>
                            </div>
                        {% endif %}
                        
                        <h3 class="text-xl font-bold text-gray-900 mb-2">{{ logement.titre }}</h3>
                        <p class="text-gray-600 text-sm mb-4">
                            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            {{ logement.adresse }}
                        </p>
                        
                        <div class="flex gap-2 mb-4 flex-wrap">
                            <span class="inline-flex items-center bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-semibold">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                                </svg>
                                {{ logement.nombreChambres }} ch.
                            </span>
                            <span class="inline-flex items-center bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-semibold">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                </svg>
                                {{ logement.capacite }} pers.
                            </span>
                            {% if logement.type %}
                                <span class="inline-flex items-center bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm font-semibold">
                                    {{ logement.type }}
                                </span>
                            {% endif %}
                        </div>

                        <div class="border-t border-gray-200 pt-4">
                            <div class="text-center">
                                <p class="text-3xl font-bold text-gray-900">{{ logement.prixParNuit }}€</p>
                                <p class="text-sm text-gray-600">par nuit</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const dateDebut = document.getElementById('reservation_dateDebut');
    const dateFin = document.getElementById('reservation_dateFin');
    const prixParNuit = {{ logement.prixParNuit }};

    function calculerPrix() {
        if (dateDebut.value && dateFin.value) {
            const debut = new Date(dateDebut.value);
            const fin = new Date(dateFin.value);
            const diffTime = Math.abs(fin - debut);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            
            if (diffDays > 0) {
                const total = diffDays * prixParNuit;
                document.getElementById('nombreNuits').textContent = diffDays + ' nuit' + (diffDays > 1 ? 's' : '');
                document.getElementById('montantTotal').textContent = total.toFixed(2) + '€';
            } else {
                document.getElementById('nombreNuits').textContent = '-';
                document.getElementById('montantTotal').textContent = '-';
            }
        }
    }

    dateDebut.addEventListener('change', calculerPrix);
    dateFin.addEventListener('change', calculerPrix);
    
    // Calculer au chargement si les dates sont déjà remplies
    calculerPrix();
});
</script>
{% endblock %}
