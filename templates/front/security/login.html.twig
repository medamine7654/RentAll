{% extends 'front/base.html.twig' %}

{% block title %}Connexion - RentAll{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md bg-white rounded-xl shadow-lg p-8">

        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold">Bon retour</h1>
            <p class="text-gray-600">Connectez-vous a votre compte</p>
        </div>

        {% if error %}
            {% set auth_error_message = error.messageKey|trans(error.messageData, 'security') %}
            <div class="mb-4 p-3 bg-red-100 text-red-700 rounded">
                {{ auth_error_message }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" class="space-y-4" novalidate data-turbo="false">

            <div>
                <label class="block text-sm font-medium">Email</label>
                <input
                    type="email"
                    name="_username"
                    value="{{ last_username }}"
                    class="w-full px-3 py-2 border rounded-lg"
                >
            </div>

            <div>
                <label class="block text-sm font-medium">Mot de passe</label>
                <input
                    type="password"
                    name="_password"
                    class="w-full px-3 py-2 border rounded-lg"
                >
            </div>

            <div class="flex items-center">
                <input type="checkbox" name="_remember_me" class="mr-2">
                <label>Se souvenir de moi</label>
            </div>
            <div class="text-right -mt-2">
                <a href="{{ path('app_forgot_password_request') }}" class="text-sm text-blue-600 hover:underline">
                    Mot de passe oublie ?
                </a>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit"
                class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
                Se connecter
            </button>
        </form>

        <div class="my-5 flex items-center">
            <div class="h-px bg-gray-200 flex-1"></div>
            <span class="px-3 text-xs text-gray-500">ou</span>
            <div class="h-px bg-gray-200 flex-1"></div>
        </div>

        <button type="button" id="face-login-direct" class="w-full border border-gray-300 text-gray-700 py-2 rounded-lg hover:bg-gray-50">
            Reconnaissance faciale
        </button>
        <p class="text-xs text-gray-500 mt-2 text-center">Un clic lance automatiquement la verification faciale.</p>
        <form id="face-login-form" method="post" action="{{ path('app_login_face') }}" enctype="multipart/form-data" class="hidden" novalidate data-turbo="false">
            <input type="hidden" name="_token" value="{{ csrf_token('face-login') }}">
            <input id="face-login-file" type="file" name="faceLoginImage" accept="image/*" class="hidden">
        </form>

        <p class="mt-6 text-center text-sm">
            Vous n'avez pas de compte ?
            <a href="{{ path('app_register') }}" class="text-blue-600 font-semibold">
                S'inscrire
            </a>
        </p>

        {% if reactivation_email is not empty or (error and 'banni' in (error.messageKey|trans(error.messageData, 'security'))) %}
            <div class="mt-6 border border-amber-200 bg-amber-50 rounded-lg p-4">
                <p class="text-sm font-semibold text-amber-900">Demande de recuperation de compte</p>
                <p class="text-xs text-amber-800 mt-1">
                    Ecrivez votre message puis validez. L'admin recevra une notification.
                </p>
                <form method="post" action="{{ path('app_request_reactivation') }}" class="mt-3 space-y-2" novalidate>
                    <input type="hidden" name="_token" value="{{ csrf_token('request-reactivation') }}">
                    <input type="email" name="email" value="{{ reactivation_email|default(last_username) }}" required class="w-full px-3 py-2 border rounded-lg text-sm" placeholder="Votre email">
                    <textarea name="note" rows="3" class="w-full px-3 py-2 border rounded-lg text-sm" placeholder="Votre message a l'admin" required></textarea>
                    <button type="submit" class="w-full bg-amber-600 text-white py-2 rounded-lg hover:bg-amber-700 text-sm">
                        Valider la demande
                    </button>
                </form>
            </div>
        {% endif %}

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('face-login-form');
        const trigger = document.getElementById('face-login-direct');
        const fileInput = document.getElementById('face-login-file');

        if (!trigger || !form || !fileInput) {
            return;
        }

        trigger.addEventListener('click', async function () {
            const originalText = trigger.textContent;
            trigger.textContent = 'Verification en cours...';
            trigger.setAttribute('disabled', 'disabled');
            try {
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    throw new Error('Camera non supportee');
                }

                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
                const video = document.createElement('video');
                video.setAttribute('playsinline', 'true');
                video.srcObject = stream;
                await video.play();

                await new Promise(function (resolve) {
                    setTimeout(resolve, 700);
                });

                const canvas = document.createElement('canvas');
                canvas.width = video.videoWidth || 640;
                canvas.height = video.videoHeight || 480;
                const context = canvas.getContext('2d');
                if (!context) {
                    throw new Error('Capture impossible');
                }
                context.drawImage(video, 0, 0, canvas.width, canvas.height);

                const blob = await new Promise(function (resolve) {
                    canvas.toBlob(resolve, 'image/jpeg', 0.92);
                });
                if (!blob) {
                    throw new Error('Capture vide');
                }

                const capturedFile = new File([blob], 'live-face.jpg', { type: 'image/jpeg' });
                const dt = new DataTransfer();
                dt.items.add(capturedFile);
                fileInput.files = dt.files;

                stream.getTracks().forEach(function (track) {
                    track.stop();
                });

                form.submit();
            } catch (e) {
                alert('Echec de la reconnaissance faciale. Autorisez la camera et reessayez.');
                trigger.textContent = originalText;
                trigger.removeAttribute('disabled');
                fileInput.value = '';
            }
        });
    });
</script>
{% endblock %}
