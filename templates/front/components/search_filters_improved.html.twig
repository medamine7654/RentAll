{# Improved Search Filters Component with Live Search #}
<div class="glass-effect rounded-2xl shadow-2xl p-8 mb-8 border border-white/20" 
     data-controller="live-search"
     data-live-search-url-value="{{ path('api_search_logements') }}"
     data-live-search-category-value="{{ filters.category ?? '' }}"
     data-live-search-min-price-value="{{ filters.minPrice ?? '' }}"
     data-live-search-max-price-value="{{ filters.maxPrice ?? '' }}"
     data-live-search-guests-value="{{ filters.guests ?? '' }}">
    <form method="get" action="{{ path('app_home') }}">
        {# Main Search Bar #}
        <div class="flex gap-3">
            <div class="relative flex-1">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <input 
                    type="text" 
                    name="location"
                    placeholder="Rechercher par localisation ou titre..."
                    value="{{ filters.location ?? '' }}"
                    class="search-box-shadow w-full pl-14 pr-14 py-5 border-2 border-transparent rounded-2xl focus:ring-0 focus:border-purple-500 text-lg font-medium transition-all duration-300"
                    data-live-search-target="input"
                    data-action="input->live-search#search"
                    autocomplete="off"
                >
                <!-- Loading indicator -->
                <div class="absolute right-4 top-1/2 -translate-y-1/2 hidden" data-live-search-target="loading">
                    <svg class="animate-spin h-6 w-6 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
            </div>
            
            <button 
                type="submit"
                class="btn-gradient px-10 py-5 text-white rounded-2xl font-bold text-lg flex items-center gap-2 transition-all duration-300"
            >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                Rechercher
            </button>
            
            <button 
                type="button"
                onclick="document.getElementById('advancedFilters').classList.toggle('hidden')"
                class="px-8 py-5 bg-white text-gray-700 rounded-2xl hover:bg-gray-50 transition font-bold text-lg flex items-center gap-2 shadow-lg"
            >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                </svg>
                Filtres
                {% set activeFiltersCount = 0 %}
                {% if filters.category %}{% set activeFiltersCount = activeFiltersCount + 1 %}{% endif %}
                {% if filters.minPrice %}{% set activeFiltersCount = activeFiltersCount + 1 %}{% endif %}
                {% if filters.maxPrice %}{% set activeFiltersCount = activeFiltersCount + 1 %}{% endif %}
                {% if filters.guests %}{% set activeFiltersCount = activeFiltersCount + 1 %}{% endif %}
                
                {% if activeFiltersCount > 0 %}
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-gradient-to-r from-purple-600 to-pink-600 text-xs text-white font-bold shadow-lg">
                        {{ activeFiltersCount }}
                    </span>
                {% endif %}
            </button>
        </div>

        {# Advanced Filters Panel (Hidden by default) #}
        <div id="advancedFilters" class="hidden mt-6 pt-6 border-t border-gray-200">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Filtres avancés</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                {# Type de logement #}
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Type de logement</label>
                    <select name="category" 
                            class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                            data-action="change->live-search#updateFilters">
                        <option value="">Tous les types</option>
                        <option value="Appartement" {% if filters.category == 'Appartement' %}selected{% endif %}>Appartement</option>
                        <option value="Maison" {% if filters.category == 'Maison' %}selected{% endif %}>Maison</option>
                        <option value="Studio" {% if filters.category == 'Studio' %}selected{% endif %}>Studio</option>
                        <option value="Villa" {% if filters.category == 'Villa' %}selected{% endif %}>Villa</option>
                        <option value="Loft" {% if filters.category == 'Loft' %}selected{% endif %}>Loft</option>
                        <option value="Chalet" {% if filters.category == 'Chalet' %}selected{% endif %}>Chalet</option>
                    </select>
                </div>

                {# Prix minimum #}
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Prix min (€/nuit)</label>
                    <input 
                        type="number" 
                        name="minPrice"
                        placeholder="0"
                        value="{{ filters.minPrice ?? '' }}"
                        min="0"
                        step="10"
                        class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                        data-action="change->live-search#updateFilters"
                    >
                </div>

                {# Prix maximum #}
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Prix max (€/nuit)</label>
                    <input 
                        type="number" 
                        name="maxPrice"
                        placeholder="1000"
                        value="{{ filters.maxPrice ?? '' }}"
                        min="0"
                        step="10"
                        class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                        data-action="change->live-search#updateFilters"
                    >
                </div>

                {# Nombre de voyageurs #}
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Voyageurs</label>
                    <select name="guests" 
                            class="w-full px-4 py-3 border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                            data-action="change->live-search#updateFilters">
                        <option value="">Tous</option>
                        <option value="1" {% if filters.guests == '1' %}selected{% endif %}>1 personne</option>
                        <option value="2" {% if filters.guests == '2' %}selected{% endif %}>2 personnes</option>
                        <option value="3" {% if filters.guests == '3' %}selected{% endif %}>3 personnes</option>
                        <option value="4" {% if filters.guests == '4' %}selected{% endif %}>4+ personnes</option>
                        <option value="6" {% if filters.guests == '6' %}selected{% endif %}>6+ personnes</option>
                    </select>
                </div>
            </div>

            {# Action Buttons #}
            <div class="flex gap-4 mt-6">
                <button 
                    type="submit"
                    class="flex-1 bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition font-bold shadow-lg"
                >
                    Appliquer les filtres
                </button>
                
                {% if filters.category or filters.minPrice or filters.maxPrice or filters.guests %}
                    <a 
                        href="{{ path('app_home', {location: filters.location}) }}"
                        class="bg-gray-200 text-gray-800 px-6 py-3 rounded-lg hover:bg-gray-300 transition font-semibold"
                    >
                        Réinitialiser les filtres
                    </a>
                {% endif %}
            </div>
        </div>

        {# Active Filters Display #}
        {% if filters.location or filters.category or filters.minPrice or filters.maxPrice or filters.guests %}
            <div class="flex flex-wrap gap-2 mt-4">
                <span class="text-sm font-semibold text-gray-700">Filtres actifs:</span>
                
                {% if filters.location %}
                    <span class="inline-flex items-center bg-blue-100 text-blue-800 px-3 py-1.5 rounded-full text-sm font-semibold">
                        📍 {{ filters.location }}
                        <a href="{{ path('app_home', filters|merge({location: null})) }}" class="ml-2 hover:text-blue-900 font-bold">×</a>
                    </span>
                {% endif %}
                
                {% if filters.category %}
                    <span class="inline-flex items-center bg-green-100 text-green-800 px-3 py-1.5 rounded-full text-sm font-semibold">
                        🏠 {{ filters.category }}
                        <a href="{{ path('app_home', filters|merge({category: null})) }}" class="ml-2 hover:text-green-900 font-bold">×</a>
                    </span>
                {% endif %}
                
                {% if filters.minPrice %}
                    <span class="inline-flex items-center bg-purple-100 text-purple-800 px-3 py-1.5 rounded-full text-sm font-semibold">
                        💰 Min: {{ filters.minPrice }}€
                        <a href="{{ path('app_home', filters|merge({minPrice: null})) }}" class="ml-2 hover:text-purple-900 font-bold">×</a>
                    </span>
                {% endif %}
                
                {% if filters.maxPrice %}
                    <span class="inline-flex items-center bg-purple-100 text-purple-800 px-3 py-1.5 rounded-full text-sm font-semibold">
                        💰 Max: {{ filters.maxPrice }}€
                        <a href="{{ path('app_home', filters|merge({maxPrice: null})) }}" class="ml-2 hover:text-purple-900 font-bold">×</a>
                    </span>
                {% endif %}
                
                {% if filters.guests %}
                    <span class="inline-flex items-center bg-orange-100 text-orange-800 px-3 py-1.5 rounded-full text-sm font-semibold">
                        👥 {{ filters.guests }}+ personnes
                        <a href="{{ path('app_home', filters|merge({guests: null})) }}" class="ml-2 hover:text-orange-900 font-bold">×</a>
                    </span>
                {% endif %}
            </div>
        {% endif %}
    </form>
</div>

<script>
// Auto-open filters if any advanced filter is active
document.addEventListener('DOMContentLoaded', function() {
    const hasAdvancedFilters = {{ (filters.category or filters.minPrice or filters.maxPrice or filters.guests) ? 'true' : 'false' }};
    if (hasAdvancedFilters) {
        document.getElementById('advancedFilters').classList.remove('hidden');
    }
});
</script>
