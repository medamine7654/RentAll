{% extends 'front/base.html.twig' %}

{% block title %}Covoiturage - RentAll{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-gray-50 via-purple-50 to-indigo-50 py-8">
    <div class="container mx-auto px-4">
        {# Hero Section #}
        <section class="mb-12 text-center">
            <div class="inline-block mb-4">
                <div class="w-20 h-20 mx-auto bg-gradient-to-br from-purple-600 via-indigo-600 to-blue-600 rounded-2xl flex items-center justify-center shadow-xl animate-fadeInUp">
                    <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17h6m-8 0a2 2 0 100 4 2 2 0 000-4zm10 0a2 2 0 100 4 2 2 0 000-4zM3 7h18M5 17l1.5-6h11L19 17"/>
                    </svg>
                </div>
            </div>
            <h1 class="text-5xl font-bold bg-gradient-to-r from-purple-600 via-indigo-600 to-blue-600 bg-clip-text text-transparent mb-4 animate-fadeInUp">
                Covoiturage
            </h1>
            <p class="text-xl text-gray-600 mb-8 animate-fadeInUp">Trouvez un trajet ou proposez le vôtre</p>
            <a href="{{ path('app_covoiturage_create') }}" 
               class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-2xl hover:from-purple-700 hover:to-indigo-700 transition-all font-bold text-lg shadow-2xl hover:shadow-purple-500/50 hover:scale-105 transform animate-fadeInUp">
                <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Ajouter un covoiturage
            </a>
        </section>

        {# Search Bar with Filters #}
        <section class="mb-8 animate-fadeInUp">
            <div class="bg-white/80 backdrop-blur-lg rounded-2xl shadow-xl border border-white/20 p-6">
                <form method="get" novalidate>
                    {# Main Search Bar #}
                    <div class="flex gap-3 mb-4">
                        <div class="flex-1 relative">
                            <svg class="absolute left-4 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            </svg>
                            <input
                                type="text"
                                name="search"
                                value="{{ filters.search }}"
                                placeholder="Rechercher un trajet (départ, destination, ville...)"
                                class="w-full rounded-xl border-2 border-gray-200 pl-12 pr-4 py-4 text-base focus:border-purple-500 focus:ring-4 focus:ring-purple-500/20 transition-all"
                            >
                        </div>
                        
                        <button type="button" 
                                onclick="document.getElementById('advanced-filters').classList.toggle('hidden')"
                                class="px-6 py-4 bg-white border-2 border-gray-200 text-gray-700 rounded-xl hover:border-purple-500 hover:text-purple-600 transition-all font-medium flex items-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                            </svg>
                            Filtres
                        </button>
                        
                        <button type="submit" class="px-8 py-4 rounded-xl bg-gradient-to-r from-purple-600 to-indigo-600 text-white hover:from-purple-700 hover:to-indigo-700 shadow-lg hover:shadow-xl transition-all hover:scale-105 transform font-bold">
                            Rechercher
                        </button>
                    </div>
                    
                    {# Advanced Filters (Hidden by default) #}
                    <div id="advanced-filters" class="hidden pt-4 border-t border-gray-200">
                        <div class="grid grid-cols-1 gap-4 md:grid-cols-4">
                            <div class="relative">
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    <svg class="w-4 h-4 inline mr-1 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    </svg>
                                    Départ
                                </label>
                                <input
                                    type="text"
                                    name="depart"
                                    value="{{ filters.depart }}"
                                    placeholder="Ville de départ"
                                    class="w-full rounded-xl border-2 border-gray-200 px-4 py-3 text-sm focus:border-green-500 focus:ring-4 focus:ring-green-500/20 transition-all"
                                >
                            </div>
                            
                            <div class="relative">
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    <svg class="w-4 h-4 inline mr-1 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    </svg>
                                    Destination
                                </label>
                                <input
                                    type="text"
                                    name="destination"
                                    value="{{ filters.destination }}"
                                    placeholder="Ville d'arrivée"
                                    class="w-full rounded-xl border-2 border-gray-200 px-4 py-3 text-sm focus:border-red-500 focus:ring-4 focus:ring-red-500/20 transition-all"
                                >
                            </div>
                            
                            <div class="relative">
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"></path>
                                    </svg>
                                    Trier par
                                </label>
                                <select
                                    name="sort"
                                    class="w-full rounded-xl border-2 border-gray-200 px-4 py-3 text-sm focus:border-purple-500 focus:ring-4 focus:ring-purple-500/20 transition-all"
                                >
                                    <option value="date_desc" {{ filters.sort == 'date_desc' ? 'selected' : '' }}>Date (plus récent)</option>
                                    <option value="date_asc" {{ filters.sort == 'date_asc' ? 'selected' : '' }}>Date (plus ancien)</option>
                                    <option value="places_desc" {{ filters.sort == 'places_desc' ? 'selected' : '' }}>Places (desc)</option>
                                    <option value="places_asc" {{ filters.sort == 'places_asc' ? 'selected' : '' }}>Places (asc)</option>
                                </select>
                            </div>
                            
                            <div class="flex items-end">
                                <a href="{{ path('app_covoiturage') }}" 
                                   class="w-full text-center px-4 py-3 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition-all text-sm font-medium">
                                    Réinitialiser
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </section>

        {# Results Count #}
        <div class="mb-6 flex items-center justify-between animate-fadeInUp">
            <div class="text-gray-600">
                <span class="inline-flex items-center px-4 py-2 bg-white/80 backdrop-blur-lg rounded-full shadow-md border border-white/20">
                    <svg class="w-5 h-5 mr-2 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17h6m-8 0a2 2 0 100 4 2 2 0 000-4zm10 0a2 2 0 100 4 2 2 0 000-4zM3 7h18M5 17l1.5-6h11L19 17"/>
                    </svg>
                    <span class="font-bold text-gray-900">{{ trips|length }}</span>
                    <span class="ml-1">trajet{{ trips|length > 1 ? 's' : '' }} trouvé{{ trips|length > 1 ? 's' : '' }}</span>
                </span>
            </div>
        </div>

        {# Trips List #}
        {% if trips|length > 0 %}
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 animate-fadeInUp">
                {% for trip in trips %}
                    {% set reserved = participantsCountByTrip[trip.id]|default(0) %}
                    {% set remaining = trip.places - reserved %}
                    
                    <article class="group relative bg-white/80 backdrop-blur-lg rounded-2xl border-2 border-white/20 p-6 shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300 overflow-hidden">
                        {# Gradient overlay on hover #}
                        <div class="absolute inset-0 bg-gradient-to-br from-purple-600/5 to-indigo-600/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>
                        
                        <div class="relative z-10">
                            {# Header with route #}
                            <div class="flex items-center gap-3 mb-4">
                                <div class="flex-1">
                                    <div class="flex items-center gap-2 mb-2">
                                        <div class="w-3 h-3 bg-green-500 rounded-full shadow-lg shadow-green-500/50"></div>
                                        <h3 class="font-bold text-gray-900 text-lg">{{ trip.depart }}</h3>
                                    </div>
                                    <div class="flex items-center gap-2 ml-1">
                                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                                        </svg>
                                    </div>
                                    <div class="flex items-center gap-2 mt-2">
                                        <div class="w-3 h-3 bg-red-500 rounded-full shadow-lg shadow-red-500/50"></div>
                                        <h3 class="font-bold text-gray-900 text-lg">{{ trip.destination }}</h3>
                                    </div>
                                </div>
                                
                                {# Places badge #}
                                <div class="text-center">
                                    <div class="inline-flex flex-col items-center px-4 py-2 bg-gradient-to-br from-purple-100 to-indigo-100 rounded-xl border-2 border-purple-200">
                                        <span class="text-2xl font-bold text-purple-700">{{ remaining > 0 ? remaining : 0 }}</span>
                                        <span class="text-xs text-purple-600 font-medium">place{{ remaining > 1 ? 's' : '' }}</span>
                                    </div>
                                </div>
                            </div>

                            {# Date and time #}
                            <div class="flex items-center gap-2 mb-3 text-gray-600">
                                <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                                <span class="font-medium">{{ trip.dateDepart|date('d/m/Y à H:i') }}</span>
                            </div>

                            {# Driver info #}
                            <div class="flex items-center gap-2 mb-4 text-sm text-gray-600">
                                <div class="w-8 h-8 bg-gradient-to-br from-purple-500 to-indigo-500 rounded-full flex items-center justify-center text-white font-bold shadow-lg">
                                    {{ trip.conducteur.email|first|upper }}
                                </div>
                                <span>{{ trip.conducteur.email|split('@')[0] }}</span>
                            </div>

                            {# Action button #}
                            <div class="mt-4 pt-4 border-t border-gray-200">
                                {% if app.user and trip.conducteur and app.user.id == trip.conducteur.id %}
                                    <span class="inline-flex items-center justify-center w-full px-4 py-3 bg-gray-100 text-gray-600 rounded-xl text-sm font-medium">
                                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        Votre trajet
                                    </span>
                                {% elseif app.user and isBookedByTrip[trip.id]|default(false) %}
                                    <div class="flex flex-col gap-2">
                                        <span class="inline-flex items-center justify-center px-4 py-2 bg-orange-100 text-orange-700 rounded-xl text-sm font-bold">
                                            ⏳ Demande envoyée
                                        </span>
                                        <a href="{{ path('app_covoiturage_my_trips') }}" 
                                           class="inline-flex items-center justify-center px-4 py-2 bg-white border-2 border-purple-200 text-purple-700 rounded-xl hover:bg-purple-50 transition text-sm font-medium">
                                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                            </svg>
                                            Voir mes trajets
                                        </a>
                                    </div>
                                {% elseif remaining <= 0 %}
                                    <span class="inline-flex items-center justify-center w-full px-4 py-3 bg-red-100 text-red-700 rounded-xl text-sm font-bold">
                                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                        </svg>
                                        Complet
                                    </span>
                                {% else %}
                                    <form method="post" action="{{ path('app_covoiturage_book', {id: trip.id}) }}" novalidate>
                                        <input type="hidden" name="_token" value="{{ csrf_token('book-covoiturage' ~ trip.id) }}">
                                        <button type="submit" class="w-full px-4 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-xl hover:from-purple-700 hover:to-indigo-700 transition-all font-bold text-sm shadow-lg hover:shadow-xl hover:scale-105 transform">
                                            <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                                            </svg>
                                            Envoyer une demande
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <div class="bg-white/80 backdrop-blur-lg rounded-2xl border-2 border-dashed border-gray-300 p-12 text-center shadow-xl animate-fadeInUp">
                <div class="inline-block p-6 bg-gradient-to-br from-gray-100 to-gray-200 rounded-full mb-6">
                    <svg class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17h6m-8 0a2 2 0 100 4 2 2 0 000-4zm10 0a2 2 0 100 4 2 2 0 000-4zM3 7h18M5 17l1.5-6h11L19 17"/>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Aucun trajet trouvé</h3>
                <p class="text-gray-600 mb-6">Essayez de modifier vos critères de recherche ou créez votre propre trajet</p>
                <a href="{{ path('app_covoiturage_create') }}" 
                   class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-xl hover:from-purple-700 hover:to-indigo-700 transition-all font-bold shadow-lg">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Créer un trajet
                </a>
            </div>
        {% endif %}
    </div>
</div>

<style>
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.animate-fadeInUp {
    animation: fadeInUp 0.6s ease-out forwards;
}

.animate-fadeInUp:nth-child(1) { animation-delay: 0.1s; }
.animate-fadeInUp:nth-child(2) { animation-delay: 0.2s; }
.animate-fadeInUp:nth-child(3) { animation-delay: 0.3s; }
</style>
{% endblock %}
