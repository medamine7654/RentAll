{% extends 'front/base.html.twig' %}

{% block title %}Ajouter un covoiturage - RentAll{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl px-4 py-8">
    <div class="mb-6">
        <a href="{{ path('app_covoiturage') }}" class="text-sm font-medium text-blue-600 hover:text-blue-700">
            ← Retour a la liste
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {# Form Section #}
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <h1 class="text-2xl font-bold text-gray-900">Ajouter un covoiturage</h1>
            <p class="mt-1 text-sm text-gray-600">Publiez un trajet pour les autres utilisateurs.</p>

            {{ form_start(form, {'attr': {'class': 'mt-6 space-y-4', 'novalidate': 'novalidate', 'data-turbo': 'false'}}) }}
                <div>
                    {{ form_label(form.depart, 'Départ', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.depart, {'attr': {'class': 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2', 'id': 'covoiturage_depart', 'placeholder': 'Cliquez sur la carte ou saisissez l\'adresse'}}) }}
                    {{ form_errors(form.depart) }}
                    <p class="mt-1 text-xs text-gray-500">💡 Cliquez sur la carte pour sélectionner automatiquement</p>
                </div>

                <div>
                    {{ form_label(form.destination, 'Destination', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.destination, {'attr': {'class': 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2', 'id': 'covoiturage_destination', 'placeholder': 'Cliquez sur la carte ou saisissez l\'adresse'}}) }}
                    {{ form_errors(form.destination) }}
                    <p class="mt-1 text-xs text-gray-500">💡 Cliquez sur la carte pour sélectionner automatiquement</p>
                </div>

                <div>
                    {{ form_label(form.dateDepart, 'Date de départ', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.dateDepart, {'attr': {'class': 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2'}}) }}
                    {{ form_errors(form.dateDepart) }}
                </div>

                <div>
                    {{ form_label(form.places, 'Nombre de places', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.places, {'attr': {'class': 'mt-1 block w-full rounded-md border border-gray-300 px-3 py-2', 'min': 1}}) }}
                    {{ form_errors(form.places) }}
                </div>

                <button type="submit" class="w-full rounded-md bg-gradient-to-r from-purple-600 to-indigo-600 px-4 py-3 text-sm font-bold text-white hover:from-purple-700 hover:to-indigo-700 shadow-lg">
                    Publier le trajet
                </button>
            {{ form_end(form) }}
        </div>

        {# Map Section #}
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-bold text-gray-900 mb-2">Sélectionner sur la carte</h2>
            <div id="map-mode-indicator" class="mb-3 text-center">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    🟢 Cliquez pour définir le DÉPART
                </span>
            </div>
            
            <div class="mb-3 flex gap-2">
                <button type="button" onclick="mapManager.setClickMode('depart')" 
                        class="flex-1 px-3 py-2 text-sm font-medium text-green-700 bg-green-50 border border-green-200 rounded-lg hover:bg-green-100">
                    🟢 Départ
                </button>
                <button type="button" onclick="mapManager.setClickMode('destination')" 
                        class="flex-1 px-3 py-2 text-sm font-medium text-red-700 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100">
                    🔴 Destination
                </button>
            </div>
            
            <div id="map" style="height: 400px; border-radius: 0.5rem; border: 2px solid #e5e7eb;"></div>
            
            <div class="mt-3 text-xs text-gray-500">
                <p>📍 Premier clic = Départ (marqueur vert)</p>
                <p>📍 Deuxième clic = Destination (marqueur rouge)</p>
                <p>🗺️ Utilisez les boutons ci-dessus pour changer le mode</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" data-turbo-track="reload"></script>
    <script src="{{ asset('js/leaflet-map.js') }}" data-turbo-track="reload"></script>
    <script>
        // Initialize map when page loads
        let mapManager;
        document.addEventListener('DOMContentLoaded', function() {
            mapManager = new window.LeafletMapManager('map', {
                defaultCenter: [46.603354, 1.888334], // Center of France
                defaultZoom: 6,
                autoSwitch: true
            });
        });
    </script>
{% endblock %}
