{% extends 'front/base.html.twig' %}

{% block title %}Modifier votre avis - RentAll{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-12">
    <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto">
            {# Messages flash #}
            {% for message in app.flashes('success') %}
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                    {{ message }}
                </div>
            {% endfor %}

            <div class="bg-white rounded-xl shadow-lg p-8">
                <h1 class="text-3xl font-bold text-gray-900 mb-6">Modifier votre avis</h1>

                {# Résumé de la réservation #}
                <div class="bg-gradient-to-r from-blue-50 to-blue-100 rounded-lg p-6 mb-8 border border-blue-200">
                    <div class="flex items-start">
                        {% if avis.reservation.logement.image %}
                            <img src="{{ avis.reservation.logement.image }}" 
                                 class="w-24 h-24 rounded-lg object-cover mr-4" 
                                 alt="{{ avis.reservation.logement.titre }}">
                        {% else %}
                            <div class="w-24 h-24 bg-gradient-to-br from-blue-400 to-blue-600 rounded-lg flex items-center justify-center mr-4">
                                <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                                </svg>
                            </div>
                        {% endif %}
                        <div>
                            <h3 class="font-bold text-gray-900 text-lg mb-1">{{ avis.reservation.logement.titre }}</h3>
                            <p class="text-sm text-gray-700 mb-1">
                                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                                Séjour du {{ avis.reservation.dateDebut|date('d/m/Y') }} au {{ avis.reservation.dateFin|date('d/m/Y') }}
                            </p>
                        </div>
                    </div>
                </div>

                {{ form_start(form, {'attr': {'data-turbo': 'false', 'novalidate': 'novalidate'}}) }}
                    <div class="space-y-6">
                        <div>
                            {{ form_label(form.note, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                            {{ form_widget(form.note) }}
                            {% if form.note.vars.errors|length > 0 %}
                                <div class="text-red-600 text-sm mt-1">
                                    {{ form_errors(form.note) }}
                                </div>
                            {% endif %}
                        </div>

                        <div>
                            {{ form_label(form.commentaire, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}
                            {{ form_widget(form.commentaire) }}
                            {% if form.commentaire.vars.errors|length > 0 %}
                                <div class="text-red-600 text-sm mt-1">
                                    {{ form_errors(form.commentaire) }}
                                </div>
                            {% endif %}
                            <p class="text-sm text-gray-500 mt-1">Minimum 10 caractères</p>
                        </div>

                        <div class="flex gap-4 pt-4">
                            <button type="submit" class="flex-1 bg-blue-600 text-white py-4 rounded-lg hover:bg-blue-700 font-bold text-lg shadow-lg transition">
                                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                                Enregistrer les modifications
                            </button>
                            <a href="{{ path('app_reservation_show', {id: avis.reservation.id}) }}" 
                               class="flex-1 bg-gray-200 text-gray-800 py-4 rounded-lg hover:bg-gray-300 font-semibold text-center flex items-center justify-center transition">
                                Annuler
                            </a>
                        </div>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
