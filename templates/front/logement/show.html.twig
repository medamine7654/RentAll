{% extends 'front/base.html.twig' %}

{% block title %}{{ logement.titre }} - RentAll{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-b from-gray-50 to-white">
    {# Image principale #}
    <div class="w-full h-[500px] bg-gray-200 relative overflow-hidden">
        {% if logement.image %}
            <img src="{{ logement.image }}" 
                 class="w-full h-full object-cover" 
                 alt="{{ logement.titre }}">
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
        {% else %}
            <div class="w-full h-full bg-gradient-to-br from-purple-400 via-pink-500 to-red-500 flex items-center justify-center">
                <svg class="w-40 h-40 text-white opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
            </div>
        {% endif %}
    </div>

    <div class="container mx-auto px-4 py-10">
        <div class="max-w-7xl mx-auto">
            <div class="grid lg:grid-cols-3 gap-10">
                {# Contenu principal #}
                <div class="lg:col-span-2">
                    <div class="bg-white rounded-2xl shadow-xl p-8 mb-8">
                        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{{ logement.titre }}</h1>
                        
                        <div class="flex items-center text-gray-600 mb-8">
                            <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            <span class="text-lg">{{ logement.adresse }}</span>
                        </div>

                        <div class="flex flex-wrap gap-6 mb-10 pb-8 border-b border-gray-200">
                            <div class="flex items-center bg-gradient-to-br from-blue-50 to-indigo-50 px-5 py-4 rounded-2xl shadow-md hover:shadow-lg transition border border-blue-100">
                                <div class="bg-gradient-to-br from-blue-500 to-indigo-600 p-3 rounded-xl mr-4">
                                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-600 font-medium">Chambres</p>
                                    <p class="font-bold text-gray-900 text-xl">{{ logement.nombreChambres }}</p>
                                </div>
                            </div>
                            {% if logement.capacite %}
                                <div class="flex items-center bg-gradient-to-br from-green-50 to-emerald-50 px-5 py-4 rounded-2xl shadow-md hover:shadow-lg transition border border-green-100">
                                    <div class="bg-gradient-to-br from-green-500 to-emerald-600 p-3 rounded-xl mr-4">
                                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-sm text-gray-600 font-medium">Voyageurs</p>
                                        <p class="font-bold text-gray-900 text-xl">{{ logement.capacite }}</p>
                                    </div>
                                </div>
                            {% endif %}
                            {% if logement.type %}
                                <div class="flex items-center bg-gradient-to-br from-purple-50 to-pink-50 px-5 py-4 rounded-2xl shadow-md hover:shadow-lg transition border border-purple-100">
                                    <div class="bg-gradient-to-br from-purple-500 to-pink-600 p-3 rounded-xl mr-4">
                                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-sm text-gray-600 font-medium">Type</p>
                                        <p class="font-bold text-gray-900 text-xl">{{ logement.type }}</p>
                                    </div>
                                </div>
                            {% endif %}
                        </div>

                        <div class="mb-10">
                            <h2 class="text-3xl font-bold text-gray-900 mb-5">Description</h2>
                            <p class="text-gray-700 leading-relaxed text-lg">{{ logement.description }}</p>
                        </div>

                        <div class="mb-10 bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 rounded-2xl p-8 border-2 border-indigo-100 shadow-lg">
                            <h2 class="text-2xl font-bold text-gray-900 mb-5 flex items-center">
                                <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-full flex items-center justify-center mr-4">
                                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                    </svg>
                                </div>
                                Hébergé par 
                                {% if logement.proprietaire.prenom and logement.proprietaire.nom %}
                                    {{ logement.proprietaire.prenom }} {{ logement.proprietaire.nom }}
                                {% else %}
                                    {{ logement.proprietaire.email }}
                                {% endif %}
                            </h2>
                            <div class="flex items-center">
                                <div class="w-20 h-20 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-full flex items-center justify-center text-white text-3xl font-bold shadow-xl">
                                    {% if logement.proprietaire.prenom and logement.proprietaire.nom %}
                                        {{ logement.proprietaire.prenom|first }}{{ logement.proprietaire.nom|first }}
                                    {% else %}
                                        {{ logement.proprietaire.email|first|upper }}
                                    {% endif %}
                                </div>
                                <div class="ml-5">
                                    <p class="font-bold text-gray-900 text-xl">
                                        {% if logement.proprietaire.prenom and logement.proprietaire.nom %}
                                            {{ logement.proprietaire.prenom }} {{ logement.proprietaire.nom }}
                                        {% else %}
                                            {{ logement.proprietaire.email }}
                                        {% endif %}
                                    </p>
                                    <div class="flex items-center mt-1">
                                        <svg class="w-5 h-5 text-green-500 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                        </svg>
                                        <span class="text-gray-700 font-medium">Hôte vérifié</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Section Avis #}
                        <div class="border-t border-gray-200 pt-10">
                            <div class="flex items-center justify-between mb-8">
                                <h2 class="text-3xl font-bold text-gray-900">
                                    {% if totalAvis > 0 %}
                                        <svg class="w-8 h-8 text-yellow-400 inline mr-2" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                        </svg>
                                        {{ averageRating|number_format(1, '.', '') }} • {{ totalAvis }} avis
                                    {% else %}
                                        Avis
                                    {% endif %}
                                </h2>
                            </div>

                            {% if totalAvis > 0 %}
                                <div class="space-y-6">
                                    {% for singleAvis in avis %}
                                        <div class="bg-gradient-to-br from-gray-50 to-white rounded-2xl p-6 border-2 border-gray-100 hover:border-gray-200 transition">
                                            <div class="flex items-start justify-between mb-4">
                                                <div class="flex items-center">
                                                    <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-white font-bold mr-4 shadow-md">
                                                        {% set locataire = singleAvis.reservation.locataire %}
                                                        {% if locataire.prenom and locataire.nom %}
                                                            {{ locataire.prenom|first }}{{ locataire.nom|first }}
                                                        {% else %}
                                                            {{ locataire.email|first|upper }}
                                                        {% endif %}
                                                    </div>
                                                    <div>
                                                        <p class="font-bold text-gray-900 text-lg">
                                                            {% if locataire.prenom and locataire.nom %}
                                                                {{ locataire.prenom }} {{ locataire.nom }}
                                                            {% else %}
                                                                {{ locataire.email|split('@')|first }}
                                                            {% endif %}
                                                        </p>
                                                        <p class="text-sm text-gray-600">{{ singleAvis.dateCreation|date('d/m/Y') }}</p>
                                                    </div>
                                                </div>
                                                <div class="flex items-center bg-yellow-100 px-4 py-2 rounded-full shadow-sm">
                                                    <svg class="w-5 h-5 text-yellow-500 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                                    </svg>
                                                    <span class="font-bold text-gray-900 text-lg">{{ singleAvis.note }}/5</span>
                                                </div>
                                            </div>
                                            <p class="text-gray-700 leading-relaxed text-base">{{ singleAvis.commentaire }}</p>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="text-center py-16 bg-gradient-to-br from-gray-50 to-white rounded-2xl border-2 border-gray-100">
                                    <svg class="w-20 h-20 text-gray-400 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                                    </svg>
                                    <p class="text-gray-900 font-bold text-xl mb-2">Aucun avis pour le moment</p>
                                    <p class="text-gray-600">Soyez le premier à laisser un avis après votre séjour</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {# Sidebar - Réservation #}
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl shadow-2xl p-8 sticky top-24 border-2 border-gray-100">
                        <div class="mb-8">
                            <div class="flex items-baseline">
                                <span class="text-4xl font-bold text-gray-900">{{ logement.prixParNuit }}€</span>
                                <span class="text-gray-600 ml-2 text-lg">/ nuit</span>
                            </div>
                        </div>

                        {% if logement.disponible %}
                            {% if app.user %}
                                {# Vérifier si l'utilisateur est le propriétaire #}
                                {% if app.user == logement.proprietaire %}
                                    <div class="bg-blue-50 border-2 border-blue-200 text-blue-800 py-4 rounded-xl text-center font-bold mb-6">
                                        <svg class="w-6 h-6 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                        </svg>
                                        C'est votre logement
                                    </div>
                                    <a href="{{ path('host_logement_edit', {id: logement.id}) }}" 
                                       class="block w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-4 rounded-xl hover:from-indigo-700 hover:to-purple-700 transition font-bold text-center text-lg shadow-xl hover:shadow-2xl transform hover:-translate-y-0.5 mb-6">
                                        <svg class="w-6 h-6 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                        Modifier mon logement
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_reservation_new', {id: logement.id}) }}" 
                                       class="block w-full bg-gradient-to-r from-purple-600 via-indigo-600 to-blue-600 text-white py-4 rounded-xl hover:from-purple-700 hover:via-indigo-700 hover:to-blue-700 transition font-bold text-center text-lg shadow-xl hover:shadow-2xl transform hover:-translate-y-1 mb-6 relative overflow-hidden group">
                                        <span class="relative z-10 flex items-center justify-center">
                                            <svg class="w-6 h-6 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                            </svg>
                                            Réserver maintenant
                                        </span>
                                        <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/20 to-white/0 transform -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
                                    </a>
                                    <p class="text-center text-sm text-gray-600 font-semibold">✓ Confirmation instantanée</p>
                                {% endif %}
                            {% else %}
                                <a href="{{ path('app_login') }}" 
                                   class="block w-full bg-gradient-to-r from-purple-600 via-indigo-600 to-blue-600 text-white py-4 rounded-xl hover:from-purple-700 hover:via-indigo-700 hover:to-blue-700 transition font-bold text-center text-lg shadow-xl hover:shadow-2xl transform hover:-translate-y-1 mb-6 relative overflow-hidden group">
                                    <span class="relative z-10 flex items-center justify-center">
                                        <svg class="w-6 h-6 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
                                        </svg>
                                        Se connecter pour réserver
                                    </span>
                                    <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/20 to-white/0 transform -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
                                </a>
                                <p class="text-center text-sm text-gray-600">
                                    <a href="{{ path('app_register') }}" class="text-blue-600 hover:text-blue-700 font-bold">Créer un compte</a> 
                                    pour effectuer une réservation
                                </p>
                            {% endif %}
                        {% else %}
                            <div class="bg-gray-100 text-gray-600 py-4 rounded-xl text-center font-bold mb-6 border-2 border-gray-200">
                                <svg class="w-6 h-6 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                </svg>
                                Non disponible
                            </div>
                        {% endif %}

                        <div class="border-t-2 border-gray-100 pt-6 mt-6 space-y-4">
                            <div class="flex items-start text-sm text-gray-700">
                                <svg class="w-6 h-6 text-green-500 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                </svg>
                                <span class="font-semibold">Annulation gratuite sous 3 jours</span>
                            </div>
                            <div class="flex items-start text-sm text-gray-700">
                                <svg class="w-6 h-6 text-green-500 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                </svg>
                                <span class="font-semibold">Confirmation instantanée</span>
                            </div>
                            <div class="flex items-start text-sm text-gray-700">
                                <svg class="w-6 h-6 text-green-500 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                </svg>
                                <span class="font-semibold">Paiement sécurisé</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Bouton retour #}
            <div class="mt-10">
                <a href="{{ path('app_home') }}" 
                   class="inline-flex items-center text-blue-600 hover:text-blue-700 font-bold text-lg bg-white px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transition transform hover:-translate-x-1">
                    <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Retour aux résultats
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
