{% extends 'front/base.html.twig' %}

{% block title %}Email envoye{% endblock %}

{% block body %}
<section class="min-h-screen bg-gray-100 flex items-center justify-center px-4 py-10">
    <div class="w-full max-w-md bg-white border border-gray-200 rounded-xl shadow-sm p-6">
        <h1 class="text-2xl font-bold text-gray-900">Email envoye</h1>
        <p class="text-sm text-gray-600 mt-3">
            Si un compte correspond a cet email, un message a ete envoye avec le lien de reinitialisation.
        </p>
        <p class="text-sm text-gray-600 mt-2">
            Le lien expire dans
            <span class="font-medium text-gray-800">
                {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}
            </span>.
        </p>
        <div class="mt-5">
            <a href="{{ path('app_forgot_password_request') }}"
               class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50">
                Reessayer
            </a>
        </div>
    </div>
</section>
{% endblock %}
