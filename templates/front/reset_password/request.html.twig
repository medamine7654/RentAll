{% extends 'front/base.html.twig' %}

{% block title %}Mot de passe oublie{% endblock %}

{% block body %}
<section class="min-h-screen bg-gray-100 flex items-center justify-center px-4 py-10">
    <div class="w-full max-w-md bg-white border border-gray-200 rounded-xl shadow-sm p-6">
        <h1 class="text-2xl font-bold text-gray-900">Mot de passe oublie</h1>
        <p class="text-sm text-gray-500 mt-2">
            Saisissez votre email et resolvez le captcha pour recevoir un lien de reinitialisation.
        </p>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="mt-4 rounded-lg border border-red-200 bg-red-50 text-red-700 px-3 py-2 text-sm" role="alert">
                {{ flash_error }}
            </div>
        {% endfor %}

        {{ form_start(requestForm, {'attr': {'novalidate': 'novalidate', 'class': 'space-y-4 mt-5', 'data-turbo': 'false'}}) }}
            <div>
                {{ form_label(requestForm.email, 'Email', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(requestForm.email, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-200 focus:border-blue-500', 'placeholder': 'vous@exemple.com'}}) }}
                {{ form_errors(requestForm.email) }}
            </div>

            <div>
                {{ form_label(requestForm.captcha, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(requestForm.captcha, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-200 focus:border-blue-500', 'placeholder': 'Votre reponse'}}) }}
                {{ form_errors(requestForm.captcha) }}
            </div>

            <button class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition-colors">
                Envoyer le lien de reinitialisation
            </button>
        {{ form_end(requestForm) }}
    </div>
</section>
{% endblock %}
