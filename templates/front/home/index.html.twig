{% extends 'front/base.html.twig' %}

{% block title %}
    {% if is_granted('ROLE_HOST') and not is_granted('ROLE_ADMIN') %}
        Mes Logements - RentAll
    {% else %}
        Trouvez votre séjour idéal - RentAll
    {% endif %}
{% endblock %}

{% block body %}
<div class="min-h-screen">
    {# Hero section with gradient #}
    <section class="hero-gradient py-16 mb-12">
        <div class="container mx-auto px-4 text-center text-white relative z-10">
            {% if is_granted('ROLE_HOST') and not is_granted('ROLE_ADMIN') %}
                <h1 class="text-5xl md:text-6xl font-bold mb-4 animate-fade-in-up">
                    Mes Logements
                </h1>
                <p class="text-xl mb-8 opacity-90 animate-fade-in-up" style="animation-delay: 0.1s;">
                    Gérez vos propriétés et suivez vos réservations
                </p>
                <div class="animate-fade-in-up" style="animation-delay: 0.2s;">
                    <a href="{{ path('host_logement_new') }}" 
                       class="btn-gradient inline-flex items-center px-8 py-4 text-white rounded-xl font-bold text-lg">
                        <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Ajouter un nouveau logement
                    </a>
                </div>
            {% else %}
                <h1 class="text-5xl md:text-6xl font-bold mb-4 animate-fade-in-up">
                    Trouvez votre séjour idéal
                </h1>
                <p class="text-xl mb-8 opacity-90 animate-fade-in-up" style="animation-delay: 0.1s;">
                    Découvrez des logements uniques partout dans le monde
                </p>
            {% endif %}
        </div>
    </section>

    <div class="container mx-auto px-4 pb-12">
        {# Search and filters - Only for non-hosts #}
        {% if not is_granted('ROLE_HOST') or is_granted('ROLE_ADMIN') %}
            <section class="mb-12 -mt-24 relative z-20 animate-fade-in-up" style="animation-delay: 0.3s;">
                {% include 'front/components/search_filters_improved.html.twig' with {filters: filters} %}
            </section>
        {% endif %}

        {# Results count #}
        <div class="mb-8 flex items-center justify-between">
            <div class="text-lg font-semibold text-gray-700">
                {% if is_granted('ROLE_HOST') and not is_granted('ROLE_ADMIN') %}
                    <span class="text-4xl font-bold text-gradient" data-live-search-target="count">{{ logements|length }}</span> 
                    <span class="text-xl">{{ logements|length == 1 ? 'logement' : 'logements' }}</span>
                {% else %}
                    <span class="text-4xl font-bold text-gradient" data-live-search-target="count">{{ logements|length }}</span> 
                    <span class="text-xl">{{ logements|length == 1 ? 'logement trouvé' : 'logements trouvés' }}</span>
                {% endif %}
            </div>
        </div>

    {# Logements grid #}
    <section>
        {% if isLoading %}
            {# Loading skeleton #}
            {% import 'front/components/logement_card.html.twig' as card %}
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                {% for i in 0..7 %}
                    {{ card.skeleton() }}
                {% endfor %}
            </div>
        {% elseif logements|length > 0 %}
            {# Logements grid #}
            <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" data-live-search-target="results">
                {% for logement in logements %}
                    <div class="block group">
                        <div class="card-hover overflow-hidden border-0 bg-white rounded-2xl shadow-lg">
                            <a href="{{ path('app_logement_show', {id: logement.id}) }}">
                                {# Image #}
                                <div class="relative aspect-square overflow-hidden">
                                    {% if logement.image %}
                                        <img 
                                            src="{{ logement.image }}" 
                                            alt="{{ logement.titre }}"
                                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                        >
                                    {% else %}
                                        <div class="w-full h-full bg-gradient-to-br from-purple-400 via-pink-500 to-red-500 flex items-center justify-center">
                                            <svg class="w-20 h-20 text-white opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                                            </svg>
                                        </div>
                                    {% endif %}

                                    {# Type badge #}
                                    {% if logement.type %}
                                        <div class="absolute left-3 top-3">
                                            <span class="glass-effect inline-flex items-center text-gray-900 px-3 py-1.5 rounded-full text-xs font-bold shadow-lg border border-white/20">
                                                {{ logement.type }}
                                            </span>
                                        </div>
                                    {% endif %}
                                    
                                    {# Status badge for hosts #}
                                    {% if is_granted('ROLE_HOST') and not is_granted('ROLE_ADMIN') %}
                                        <div class="absolute right-3 top-3">
                                            {% if logement.disponible %}
                                                <span class="inline-flex items-center bg-green-500 text-white px-3 py-1.5 rounded-lg text-xs font-bold shadow-md">
                                                    ✓ Disponible
                                                </span>
                                            {% else %}
                                                <span class="inline-flex items-center bg-red-500 text-white px-3 py-1.5 rounded-lg text-xs font-bold shadow-md">
                                                    ✕ Indisponible
                                                </span>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>

                                {# Card content #}
                                <div class="space-y-2 p-5">
                                    <div class="flex items-start justify-between gap-2">
                                        <h3 class="font-bold text-gray-900 line-clamp-1 text-lg">
                                            {{ logement.titre }}
                                        </h3>
                                        {% if ratings[logement.id].total > 0 %}
                                            <div class="flex items-center text-sm flex-shrink-0">
                                                <svg class="w-4 h-4 text-yellow-400 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                                </svg>
                                                <span class="font-bold text-gray-900">{{ ratings[logement.id].average|number_format(1, '.', '') }}</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <p class="text-sm text-gray-600 line-clamp-1 flex items-center">
                                        <svg class="w-4 h-4 inline mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                        </svg>
                                        {{ logement.adresse }}
                                    </p>
                                    <p class="text-sm text-gray-600 flex items-center gap-3">
                                        <span class="flex items-center">
                                            <svg class="w-4 h-4 mr-1 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                                            </svg>
                                            {{ logement.nombreChambres }} ch.
                                        </span>
                                        <span class="flex items-center">
                                            <svg class="w-4 h-4 mr-1 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                            </svg>
                                            {{ logement.capacite }} pers.
                                        </span>
                                    </p>
                                    <p class="pt-2 border-t border-gray-100">
                                        <span class="font-bold text-gray-900 text-xl">{{ logement.prixParNuit }}€</span>
                                        <span class="text-gray-600 text-sm"> / nuit</span>
                                    </p>
                                </div>
                            </a>
                            
                            {# Host action buttons #}
                            {% if is_granted('ROLE_HOST') and not is_granted('ROLE_ADMIN') %}
                                <div class="border-t border-gray-200 p-4 flex gap-2">
                                    <a href="{{ path('host_logement_edit', {id: logement.id}) }}" 
                                       class="flex-1 bg-blue-600 text-white px-4 py-2.5 rounded-lg hover:bg-blue-700 transition text-sm font-bold text-center"
                                       onclick="event.stopPropagation()">
                                        <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                        </svg>
                                        Modifier
                                    </a>
                                    <form method="post" action="{{ path('host_logement_toggle', {id: logement.id}) }}" class="flex-1" onclick="event.stopPropagation()">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ logement.id) }}">
                                        <button type="submit" 
                                                class="w-full {% if logement.disponible %}bg-orange-600 hover:bg-orange-700{% else %}bg-green-600 hover:bg-green-700{% endif %} text-white px-4 py-2.5 rounded-lg transition text-sm font-bold">
                                            {% if logement.disponible %}
                                                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
                                                </svg>
                                                Désactiver
                                            {% else %}
                                                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                </svg>
                                                Activer
                                            {% endif %}
                                        </button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            {# Empty state #}
            <div class="flex flex-col items-center justify-center py-16 text-center bg-white rounded-2xl shadow-lg">
                <div class="rounded-full bg-gradient-to-br from-blue-100 to-blue-200 p-8 mb-6">
                    <svg class="h-16 w-16 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Aucun logement trouvé</h3>
                <p class="text-gray-600 mb-6 max-w-md">
                    Essayez d'ajuster vos critères de recherche ou vos filtres pour trouver plus de résultats
                </p>
                {% if filters.location or filters.category or filters.minPrice or filters.maxPrice or filters.guests %}
                    <a href="{{ path('app_home') }}" 
                       class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-semibold">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        Réinitialiser les filtres
                    </a>
                {% endif %}
            </div>
        {% endif %}
    </section>
</div>
</div>
{% endblock %}

