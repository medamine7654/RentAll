{% extends 'admin/base.html.twig' %}

{% block title %}Participants - {{ covoiturage.depart }} → {{ covoiturage.destination }}{% endblock %}

{% block body %}
<div class="mb-6">
    <div class="flex items-center gap-3 mb-4">
        <a href="{{ path('admin_covoiturages') }}" class="text-gray-500 hover:text-gray-700">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-dark font-heading">Participants du Trajet</h1>
            <p class="text-gray-600 mt-1">
                <span class="font-medium">{{ covoiturage.depart }}</span>
                <svg class="inline w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
                <span class="font-medium">{{ covoiturage.destination }}</span>
                <span class="text-gray-400 mx-2">•</span>
                <span class="text-sm">{{ covoiturage.dateDepart|date('d/m/Y à H:i') }}</span>
            </p>
        </div>
    </div>

    {# Statistiques #}
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-xl shadow-sm p-4 border-l-4 border-orange-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">En attente</p>
                    <p class="text-2xl font-bold text-orange-600">{{ stats.en_attente }}</p>
                </div>
                <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center">
                    <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm p-4 border-l-4 border-green-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Confirmés</p>
                    <p class="text-2xl font-bold text-green-600">{{ stats.confirme }}</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm p-4 border-l-4 border-red-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Refusés</p>
                    <p class="text-2xl font-bold text-red-600">{{ stats.refuse }}</p>
                </div>
                <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center">
                    <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm p-4 border-l-4 border-gray-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Annulés</p>
                    <p class="text-2xl font-bold text-gray-600">{{ stats.annule }}</p>
                </div>
                <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center">
                    <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</div>

{# Liste des participants #}
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Passager</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date demande</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Message</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                {% for participant in participants %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-gradient-to-br from-purple-500 to-indigo-500 rounded-full flex items-center justify-center text-white font-bold">
                                    {{ participant.passager.email|first|upper }}
                                </div>
                                <div>
                                    <p class="font-medium text-dark">
                                        {% if participant.passager.prenom and participant.passager.nom %}
                                            {{ participant.passager.prenom }} {{ participant.passager.nom }}
                                        {% else %}
                                            {{ participant.passager.email|split('@')[0] }}
                                        {% endif %}
                                    </p>
                                    <p class="text-sm text-gray-500">{{ participant.passager.email }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-sm text-gray-700">
                            {{ participant.dateCreation|date('d/m/Y H:i') }}
                        </td>
                        <td class="px-4 py-3 text-sm text-gray-700">
                            {% if participant.message %}
                                <span class="italic">"{{ participant.message|slice(0, 50) }}{% if participant.message|length > 50 %}...{% endif %}"</span>
                            {% else %}
                                <span class="text-gray-400">-</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">
                            {% if participant.statut == 'en_attente' %}
                                <span class="px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-xs font-bold">⏳ En attente</span>
                            {% elseif participant.statut == 'confirme' %}
                                <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-bold">✓ Confirmé</span>
                            {% elseif participant.statut == 'refuse' %}
                                <span class="px-3 py-1 bg-red-100 text-red-700 rounded-full text-xs font-bold">✕ Refusé</span>
                            {% else %}
                                <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-xs font-bold">✕ Annulé</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-right">
                            <div class="inline-flex items-center gap-2">
                                {# Dropdown pour changer le statut #}
                                <div class="relative inline-block">
                                    <button type="button" 
                                            onclick="toggleDropdown({{ participant.id }})"
                                            class="px-3 py-1.5 text-xs rounded-lg border border-blue-200 text-blue-700 hover:bg-blue-50">
                                        Changer statut
                                    </button>
                                    <div id="dropdown-{{ participant.id }}" 
                                         class="hidden absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-10">
                                        <form method="post" action="{{ path('admin_participant_change_status', {id: participant.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('status' ~ participant.id) }}">
                                            <button type="submit" name="status" value="en_attente" 
                                                    class="w-full text-left px-4 py-2 text-sm hover:bg-orange-50 text-orange-700 rounded-t-lg">
                                                ⏳ En attente
                                            </button>
                                            <button type="submit" name="status" value="confirme" 
                                                    class="w-full text-left px-4 py-2 text-sm hover:bg-green-50 text-green-700">
                                                ✓ Confirmé
                                            </button>
                                            <button type="submit" name="status" value="refuse" 
                                                    class="w-full text-left px-4 py-2 text-sm hover:bg-red-50 text-red-700">
                                                ✕ Refusé
                                            </button>
                                            <button type="submit" name="status" value="annule" 
                                                    class="w-full text-left px-4 py-2 text-sm hover:bg-gray-50 text-gray-700 rounded-b-lg">
                                                ✕ Annulé
                                            </button>
                                        </form>
                                    </div>
                                </div>

                                {# Bouton supprimer #}
                                <form method="post" 
                                      action="{{ path('admin_participant_delete', {id: participant.id}) }}" 
                                      class="inline-block" 
                                      onsubmit="return confirm('Supprimer ce participant ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ participant.id) }}">
                                    <button type="submit" class="px-3 py-1.5 text-xs rounded-lg border border-red-200 text-red-600 hover:bg-red-50">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-4 py-8 text-center text-gray-500">
                            Aucun participant pour ce trajet.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
function toggleDropdown(id) {
    const dropdown = document.getElementById('dropdown-' + id);
    // Fermer tous les autres dropdowns
    document.querySelectorAll('[id^="dropdown-"]').forEach(el => {
        if (el.id !== 'dropdown-' + id) {
            el.classList.add('hidden');
        }
    });
    // Toggle le dropdown actuel
    dropdown.classList.toggle('hidden');
}

// Fermer les dropdowns si on clique ailleurs
document.addEventListener('click', function(event) {
    if (!event.target.closest('button[onclick^="toggleDropdown"]') && !event.target.closest('[id^="dropdown-"]')) {
        document.querySelectorAll('[id^="dropdown-"]').forEach(el => {
            el.classList.add('hidden');
        });
    }
});
</script>
{% endblock %}
