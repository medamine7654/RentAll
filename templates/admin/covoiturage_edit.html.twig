{% extends 'admin/base.html.twig' %}

{% block title %}Modifier Covoiturage - RentAdmin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
{% endblock %}

{% block body %}
<div class="max-w-6xl">
    <div class="mb-6">
        <a href="{{ path('admin_covoiturages') }}" class="text-sm font-medium text-primary hover:underline">
            <i class="fas fa-arrow-left mr-1"></i>Retour a la liste
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {# Form Section #}
        <div class="bg-white rounded-xl shadow-sm p-6">
            <h1 class="text-2xl font-bold text-dark font-heading mb-2">Modifier le covoiturage #{{ covoiturage.id }}</h1>
            <p class="text-sm text-gray-500 mb-6">Conducteur: {{ covoiturage.conducteur ? covoiturage.conducteur.email : '-' }}</p>

            {{ form_start(form, {'attr': {'class': 'space-y-4', 'novalidate': 'novalidate', 'data-turbo': 'false'}}) }}
                <div>
                    {{ form_label(form.depart, 'Départ', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.depart, {'attr': {'class': 'mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2', 'id': 'covoiturage_depart'}}) }}
                    {{ form_errors(form.depart) }}
                </div>
                <div>
                    {{ form_label(form.destination, 'Destination', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.destination, {'attr': {'class': 'mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2', 'id': 'covoiturage_destination'}}) }}
                    {{ form_errors(form.destination) }}
                </div>
                <div>
                    {{ form_label(form.dateDepart, 'Date de départ', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.dateDepart, {'attr': {'class': 'mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2'}}) }}
                    {{ form_errors(form.dateDepart) }}
                </div>
                <div>
                    {{ form_label(form.places, 'Nombre de places', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(form.places, {'attr': {'class': 'mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2', 'min': 1}}) }}
                    {{ form_errors(form.places) }}
                </div>

                <button type="submit" class="w-full px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-primary/90">
                    Enregistrer
                </button>
            {{ form_end(form) }}
        </div>

        {# Map Section #}
        <div class="bg-white rounded-xl shadow-sm p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-2">Carte interactive</h2>
            <div id="map-mode-indicator" class="mb-3 text-center">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                    🟢 Cliquez pour modifier le DÉPART
                </span>
            </div>
            
            <div class="mb-3 flex gap-2">
                <button type="button" onclick="mapManager.setClickMode('depart')" 
                        class="flex-1 px-3 py-2 text-sm font-medium text-green-700 bg-green-50 border border-green-200 rounded-lg hover:bg-green-100">
                    🟢 Départ
                </button>
                <button type="button" onclick="mapManager.setClickMode('destination')" 
                        class="flex-1 px-3 py-2 text-sm font-medium text-red-700 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100">
                    🔴 Destination
                </button>
            </div>
            
            <div id="map" style="height: 400px; border-radius: 0.5rem; border: 2px solid #e5e7eb;"></div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" data-turbo-track="reload"></script>
    <script src="{{ asset('js/leaflet-map.js') }}" data-turbo-track="reload"></script>
    <script>
        let mapManager;
        document.addEventListener('DOMContentLoaded', function() {
            mapManager = new window.LeafletMapManager('map', {
                defaultCenter: [46.603354, 1.888334],
                defaultZoom: 6,
                autoSwitch: false
            });
            
            // Display existing locations
            const depart = '{{ covoiturage.depart|e('js') }}';
            const destination = '{{ covoiturage.destination|e('js') }}';
            
            if (depart && destination) {
                mapManager.displayExistingLocations(depart, destination);
            }
        });
    </script>
{% endblock %}
