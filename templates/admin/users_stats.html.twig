{% extends 'admin/base.html.twig' %}

{% block title %}Statistiques Utilisateurs{% endblock %}

{% block body %}
{% set total = stats.total|default(0) %}
{% set totalSafe = total > 0 ? total : 1 %}
{% set activePct = ((stats.active|default(0) / totalSafe) * 100)|round(1) %}
{% set inactivePct = ((stats.inactive|default(0) / totalSafe) * 100)|round(1) %}
{% set suspendedPct = ((stats.suspended|default(0) / totalSafe) * 100)|round(1) %}
{% set bannedPct = ((stats.banned|default(0) / totalSafe) * 100)|round(1) %}
{% set flaggedPct = ((stats.flagged|default(0) / totalSafe) * 100)|round(1) %}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-dark font-heading">Statistiques Utilisateurs</h1>
        <p class="text-gray-500 mt-1">Vue globale et indicateurs de risque des comptes</p>
    </div>
    <a href="{{ path('admin_users') }}" class="px-3 py-2 border border-gray-200 rounded-lg text-sm hover:bg-gray-50">Retour a la liste</a>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-4 mb-4">
    <div class="xl:col-span-2 bg-white rounded-xl shadow-sm p-5">
        <div class="flex items-start justify-between gap-4">
            <div>
                <p class="text-sm text-gray-500">Population plateforme</p>
                <p class="text-3xl font-bold text-dark mt-1">{{ total }}</p>
                <p class="text-xs text-gray-500 mt-2">Comptes total en base</p>
            </div>
            <div class="text-right">
                <p class="text-sm text-gray-500">Taux de comptes suspects</p>
                <p class="text-2xl font-bold {% if flaggedPct >= 15 %}text-red-700{% elseif flaggedPct >= 8 %}text-orange-700{% else %}text-green-700{% endif %}">
                    {{ flaggedPct }}%
                </p>
            </div>
        </div>

        <div class="mt-5 grid grid-cols-1 sm:grid-cols-3 gap-3">
            <div class="rounded-lg border border-green-100 bg-green-50/60 p-3">
                <p class="text-xs text-green-700 font-medium uppercase tracking-wide">Actifs</p>
                <p class="text-2xl font-bold text-green-800 mt-1">{{ stats.active|default(0) }}</p>
                <p class="text-xs text-green-700/80 mt-1">{{ activePct }}%</p>
            </div>
            <div class="rounded-lg border border-red-100 bg-red-50/60 p-3">
                <p class="text-xs text-red-700 font-medium uppercase tracking-wide">Inactifs</p>
                <p class="text-2xl font-bold text-red-800 mt-1">{{ stats.inactive|default(0) }}</p>
                <p class="text-xs text-red-700/80 mt-1">{{ inactivePct }}%</p>
            </div>
            <div class="rounded-lg border border-yellow-100 bg-yellow-50/60 p-3">
                <p class="text-xs text-yellow-700 font-medium uppercase tracking-wide">Suspects</p>
                <p class="text-2xl font-bold text-yellow-800 mt-1">{{ stats.flagged|default(0) }}</p>
                <p class="text-xs text-yellow-700/80 mt-1">{{ flaggedPct }}%</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-5">
        <p class="text-sm text-gray-500">Sante globale</p>
        <p class="text-3xl font-bold text-dark mt-1">{{ (100 - flaggedPct)|round(1) }}%</p>
        <p class="text-xs mt-2 {% if flaggedPct >= 15 %}text-red-600{% elseif flaggedPct >= 8 %}text-orange-600{% else %}text-green-600{% endif %}">
            {% if flaggedPct >= 15 %}
                Niveau de risque eleve
            {% elseif flaggedPct >= 8 %}
                Niveau de risque moyen
            {% else %}
                Niveau de risque faible
            {% endif %}
        </p>

        <div class="mt-4">
            <div class="flex justify-between text-xs text-gray-500 mb-1">
                <span>Risque</span>
                <span>{{ flaggedPct }}%</span>
            </div>
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full {% if flaggedPct >= 15 %}bg-red-500{% elseif flaggedPct >= 8 %}bg-orange-500{% else %}bg-green-500{% endif %}" style="width: {{ flaggedPct }}%"></div>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <div class="bg-white rounded-xl shadow-sm p-5">
        <div class="flex items-center justify-between">
            <p class="text-sm text-gray-500">Comptes actifs</p>
            <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700">{{ activePct }}%</span>
        </div>
        <p class="text-3xl font-bold text-green-700 mt-2">{{ stats.active|default(0) }}</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5">
        <div class="flex items-center justify-between">
            <p class="text-sm text-gray-500">Comptes inactifs</p>
            <span class="text-xs px-2 py-1 rounded-full bg-red-100 text-red-700">{{ inactivePct }}%</span>
        </div>
        <p class="text-3xl font-bold text-red-700 mt-2">{{ stats.inactive|default(0) }}</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5">
        <div class="flex items-center justify-between">
            <p class="text-sm text-gray-500">Comptes suspendus</p>
            <span class="text-xs px-2 py-1 rounded-full bg-orange-100 text-orange-700">{{ suspendedPct }}%</span>
        </div>
        <p class="text-3xl font-bold text-orange-700 mt-2">{{ stats.suspended|default(0) }}</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5">
        <div class="flex items-center justify-between">
            <p class="text-sm text-gray-500">Comptes bannis</p>
            <span class="text-xs px-2 py-1 rounded-full bg-red-100 text-red-800">{{ bannedPct }}%</span>
        </div>
        <p class="text-3xl font-bold text-red-800 mt-2">{{ stats.banned|default(0) }}</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5">
        <div class="flex items-center justify-between">
            <p class="text-sm text-gray-500">Comptes suspects</p>
            <span class="text-xs px-2 py-1 rounded-full bg-yellow-100 text-yellow-700">{{ flaggedPct }}%</span>
        </div>
        <p class="text-3xl font-bold text-yellow-700 mt-2">{{ stats.flagged|default(0) }}</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5">
        <p class="text-sm text-gray-500">Administrateurs</p>
        <p class="text-3xl font-bold text-dark mt-2">{{ stats.admins|default(0) }}</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5">
        <p class="text-sm text-gray-500">Hotes</p>
        <p class="text-3xl font-bold text-dark mt-2">{{ stats.hosts|default(0) }}</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-5">
        <p class="text-sm text-gray-500">Voyageurs</p>
        <p class="text-3xl font-bold text-dark mt-2">{{ stats.guests|default(0) }}</p>
    </div>
</div>
{% endblock %}
